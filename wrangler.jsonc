{
  "name": "maintainpro-web",
  "main": "maintainpro/apps/web/.open-next/worker.js",
  "compatibility_date": "2026-05-02",
  "compatibility_flags": ["nodejs_compat"],
  "assets": {
    "directory": "maintainpro/apps/web/.open-next/assets",
    "binding": "ASSETS"
  },
  "observability": {
    "enabled": true
  },
  "build": {
    "command": "cd maintainpro && npm install && npm run cloudflare:build"
  }
}
