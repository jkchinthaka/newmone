NODE_ENV=production

# Public URLs
PORT=3000
CORS_ORIGIN=https://app.example.com
FRONTEND_URL=https://app.example.com
NEXT_PUBLIC_API_URL=https://api.example.com/api
NEXT_PUBLIC_API_BASE_URL=https://api.example.com/api
NEXT_PUBLIC_API_ORIGIN=https://api.example.com

# Managed production services
DATABASE_URL=mongodb+srv://<user>:<password>@<cluster>/<database>?retryWrites=true&w=majority
MONGODB_URI=mongodb+srv://<user>:<password>@<cluster>/<database>?retryWrites=true&w=majority
REDIS_URL=rediss://:<password>@<host>:6380

# JWT auth - use strong secret-manager values
JWT_SECRET=<secret-manager-value>
JWT_ACCESS_SECRET=<secret-manager-value>
JWT_REFRESH_SECRET=<secret-manager-value>
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=7d

# Notifications
SENDGRID_API_KEY=<secret-manager-value>
SMTP_HOST=<smtp-host>
SMTP_PORT=587
SMTP_USER=<secret-manager-value>
SMTP_PASS=<secret-manager-value>
SMTP_FROM=MaintainPro Alerts <alerts@example.com>
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# Billing and identity providers
STRIPE_SECRET_KEY=<secret-manager-value>
STRIPE_WEBHOOK_SECRET=<secret-manager-value>
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=https://api.example.com/api/auth/google/callback

# Premium integrations
RAPIDAPI_GOOGLE_MAP_PLACES_KEY=
RAPIDAPI_COPILOT_API_KEY=
RAPIDAPI_COPILOT_HOST=copilot5.p.rapidapi.com
RAPIDAPI_QR_CODE_API_KEY=
RAPIDAPI_QR_CODE_HOST=simple-qr-code-generator-cheap-and-efficient.p.rapidapi.com
RAPIDAPI_QR_CODE_COLOR=
RAPIDAPI_QR_CODE_BG_COLOR=

# Object storage
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
CLOUDINARY_ASSET_FOLDER=maintainpro/asset-documents
MINIO_ENDPOINT=<s3-compatible-endpoint>
MINIO_PORT=443
MINIO_USE_SSL=true
MINIO_ACCESS_KEY=<secret-manager-value>
MINIO_SECRET_KEY=<secret-manager-value>
MINIO_BUCKET=maintainpro-files

# Farm/weather defaults
OPENWEATHER_API_KEY=
FARM_DEFAULT_LATITUDE=6.9271
FARM_DEFAULT_LONGITUDE=79.8612
WEATHER_ALERT_FROST_THRESHOLD_C=5
WEATHER_ALERT_RAIN_THRESHOLD_MM=50
TRACEABILITY_PUBLIC_BASE_URL=https://trace.example.com
APP_VERSION=1.2.0