NODE_ENV=development

# API runtime
PORT=3000
CORS_ORIGIN=http://localhost:3001
FRONTEND_URL=http://localhost:3001

# Frontend runtime
NEXT_PUBLIC_API_BASE_URL=http://localhost:3000/api
NEXT_PUBLIC_API_ORIGIN=http://localhost:3000

# Docker-backed local services exposed to the host
DATABASE_URL=mongodb://localhost:27018/nelna?replicaSet=rs0&directConnection=true
MONGODB_URI=mongodb://localhost:27018/nelna?replicaSet=rs0&directConnection=true
REDIS_URL=redis://localhost:6380

# JWT auth - replace before shared environments
JWT_ACCESS_SECRET=replace_with_local_access_secret
JWT_REFRESH_SECRET=replace_with_local_refresh_secret
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=7d

# Notifications
SENDGRID_API_KEY=
SMTP_HOST=smtp.mailtrap.io
SMTP_PORT=587
SMTP_USER=replace_with_smtp_user
SMTP_PASS=replace_with_smtp_password
SMTP_FROM=MaintainPro Alerts <alerts@maintainpro.local>
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# Optional providers
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=http://localhost:3000/api/auth/google/callback
RAPIDAPI_GOOGLE_MAP_PLACES_KEY=
RAPIDAPI_COPILOT_API_KEY=
RAPIDAPI_COPILOT_HOST=copilot5.p.rapidapi.com
RAPIDAPI_QR_CODE_API_KEY=
RAPIDAPI_QR_CODE_HOST=simple-qr-code-generator-cheap-and-efficient.p.rapidapi.com
RAPIDAPI_QR_CODE_COLOR=
RAPIDAPI_QR_CODE_BG_COLOR=

# Object storage - Docker dev stack maps MinIO to host port 9002
MINIO_ENDPOINT=localhost
MINIO_PORT=9002
MINIO_USE_SSL=false
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=replace_with_local_minio_secret
MINIO_BUCKET=maintainpro-files

# Farm/weather defaults
OPENWEATHER_API_KEY=
FARM_DEFAULT_LATITUDE=6.9271
FARM_DEFAULT_LONGITUDE=79.8612
WEATHER_ALERT_FROST_THRESHOLD_C=5
WEATHER_ALERT_RAIN_THRESHOLD_MM=50
TRACEABILITY_PUBLIC_BASE_URL=https://trace.nelnafarm.lk
APP_VERSION=1.2.0