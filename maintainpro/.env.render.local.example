# Copy to .env.render.local (ignored by git) and fill real values.
RENDER_API_KEY=replace_with_render_api_key

# Prefer explicit service id for unambiguous deploy targeting.
RENDER_SERVICE_ID=srv-xxxxxxxxxxxxxxxxxxxx

# Optional fallback if service id is not set.
# RENDER_SERVICE_NAME=newmone

# Optional settings
RENDER_DEPLOY_CLEAR_CACHE=false
# RENDER_API_BASE_URL=https://api.render.com/v1
