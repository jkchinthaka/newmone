{
  "name": "maintainpro",
  "version": "1.2.0",
  "private": true,
  "description": "MaintainPro enterprise asset, fleet, and utility management platform",
  "packageManager": "npm@11.6.2",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "concurrently -n api,web -c cyan,magenta \"npm run dev:api\" \"npm run dev:web\"",
    "dev:api": "npm run dev --workspace @maintainpro/api",
    "dev:web": "npm run dev --workspace @maintainpro/web",
    "build": "npm run build --workspace @maintainpro/shared-types && npm run build --workspace @maintainpro/ui-components && npm run build --workspace @maintainpro/api && npm run build --workspace @maintainpro/web",
    "vercel:build": "npm run build --workspace @maintainpro/shared-types && npm run build --workspace @maintainpro/web",
    "cloudflare:build": "npm run build --workspace @maintainpro/shared-types && npm run cloudflare:build --workspace @maintainpro/web",
    "cloudflare:clean": "node scripts/cloudflare-clean-build.mjs",
    "cloudflare:rebuild": "npm run cloudflare:clean && npm run cloudflare:build",
    "cloudflare:deploy": "npm run cloudflare:build && cd apps/web && wrangler deploy",
    "cloudflare:preview": "npm run cloudflare:build && cd apps/web && wrangler dev",
    "render:build": "npm run build --workspace @maintainpro/shared-types && npm run build --workspace @maintainpro/api",
    "render:start": "node scripts/render-startup.mjs",
    "render:deploy": "node scripts/render-deploy.mjs",
    "render:deploy:dry": "node scripts/render-deploy.mjs --dry-run",
    "deploy:check": "npm run typecheck && npm run render:build && npm run vercel:build",
    "lint": "npm run lint --workspace @maintainpro/api && npm run lint --workspace @maintainpro/web",
    "typecheck": "npm run typecheck --workspace @maintainpro/api && npm run typecheck --workspace @maintainpro/web",
    "test": "npm run test --workspace @maintainpro/api",
    "test:e2e": "npm run test:e2e --workspace @maintainpro/web",
    "test:e2e:staging": "npm run test:e2e:staging --workspace @maintainpro/web",
    "test:e2e:staging:uat002": "npm run test:e2e:staging:uat002 --workspace @maintainpro/web",
    "test:e2e:staging:uat003": "npm run test:e2e:staging:uat003 --workspace @maintainpro/web",
    "uat:002:validate": "node scripts/run-uat-002-validation.mjs",
    "uat:003:validate": "node scripts/run-uat-003-validation.mjs",
    "test:e2e:staging:uat004": "npm run test:e2e:staging:uat004 --workspace @maintainpro/web",
    "uat:004:validate": "node scripts/run-uat-004-validation.mjs",
    "test:e2e:staging:uat005": "npm run test:e2e:staging:uat005 --workspace @maintainpro/web",
    "uat:005:validate": "node scripts/run-uat-005-validation.mjs",
    "uat:007:validate": "node scripts/run-uat-007-validation.mjs",
    "uat:008:validate": "node scripts/run-uat-008-validation.mjs",
    "uat:010:validate": "node scripts/run-uat-010-validation.mjs",
    "uat:011:validate": "node scripts/run-uat-011-validation.mjs",
    "uat:012:validate": "node scripts/run-uat-012-validation.mjs",
    "seed": "npm run db:seed",
    "start:api": "npm run start --workspace @maintainpro/api",
    "start:web": "npm run start --workspace @maintainpro/web",
    "start:prod": "npm run render:start",
    "db:generate": "npx prisma generate --schema ./prisma/schema.prisma",
    "db:push": "npx prisma db push --schema ./prisma/schema.prisma",
    "db:migrate": "npm run db:push",
    "db:seed": "npm run seed --workspace @maintainpro/api",
    "db:backup:resync": "npm run backup:resync --workspace @maintainpro/api --",
    "db:backup:verify": "npm run backup:verify --workspace @maintainpro/api --",
    "db:smoke": "node scripts/staging-db-smoke.mjs",
    "departments:migrate": "npm run departments:migrate --workspace @maintainpro/api",
    "phase3:migrate": "npm run phase3:migrate --workspace @maintainpro/api",
    "smoke:local": "node scripts/smoke-local.mjs",
    "smoke:deploy": "node scripts/run-smoke-with-staging-env.mjs",
    "healthcheck": "node scripts/healthcheck.mjs",
    "deployment:readiness": "npm run deployment:readiness --workspace @maintainpro/api",
    "facility:backfill:dry": "npm run facility:backfill:dry --workspace @maintainpro/api",
    "bootstrap:local": "node scripts/bootstrap-local.mjs",
    "docker:up": "docker compose -f docker-compose.yml up -d --build",
    "docker:up:dev": "docker compose -f docker-compose.dev.yml up -d --build",
    "docker:down": "docker compose -f docker-compose.yml down",
    "docker:down:dev": "docker compose -f docker-compose.dev.yml down"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "concurrently": "^9.1.2",
    "prisma": "^5.22.0"
  },
  "dependencies": {
    "mongodb": "^7.4.0"
  }
}
