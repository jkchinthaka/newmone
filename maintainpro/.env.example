# ==============================
# Core Runtime
# ==============================
# Runtime environment for API and worker services.
NODE_ENV=development
# API server port exposed by the container and local runtime.
PORT=3000
# CORS allowlist for browser origins (comma-separated if multiple).
CORS_ORIGIN=http://localhost:5173
# Public frontend base URL used in links and redirects.
FRONTEND_URL=http://localhost:5173

# ==============================
# Database and Cache
# ==============================
# PostgreSQL connection string used by Prisma.
DATABASE_URL=postgresql://maintainpro:maintainpro@postgres:5432/maintainpro?schema=public
# Redis connection URL for caching and BullMQ queues.
REDIS_URL=redis://redis:6379

# ==============================
# Authentication Tokens
# ==============================
# Secret used to sign short-lived access JWT tokens.
JWT_ACCESS_SECRET=maintainpro_access_secret_change_me_2026
# Secret used to sign long-lived refresh JWT tokens.
JWT_REFRESH_SECRET=maintainpro_refresh_secret_change_me_2026
# Access token TTL (examples: 15m, 1h).
JWT_ACCESS_EXPIRES=15m
# Refresh token TTL (examples: 7d, 30d).
JWT_REFRESH_EXPIRES=7d

# ==============================
# Cloudinary (media storage)
# ==============================
# Cloudinary cloud name.
CLOUDINARY_CLOUD_NAME=maintainpro-cloud
# Cloudinary API key.
CLOUDINARY_API_KEY=123456789012345
# Cloudinary API secret.
CLOUDINARY_API_SECRET=replace_with_cloudinary_secret

# ==============================
# Firebase Admin
# ==============================
# Firebase project identifier.
FIREBASE_PROJECT_ID=maintainpro-dev
# Firebase service account private key (escaped newlines as \\n).
FIREBASE_PRIVATE_KEY=-----BEGIN PRIVATE KEY-----\\nreplace_with_private_key\\n-----END PRIVATE KEY-----\\n
# Firebase service account client email.
FIREBASE_CLIENT_EMAIL=firebase-adminsdk@maintainpro-dev.iam.gserviceaccount.com

# ==============================
# WhatsApp Business API
# ==============================
# Meta access token for WhatsApp Cloud API.
WHATSAPP_TOKEN=EAABwzLixnjYBO_example_token
# WhatsApp phone number ID.
WHATSAPP_PHONE_ID=123456789012345
# Verification token used by WhatsApp webhook setup.
WHATSAPP_VERIFY_TOKEN=maintainpro_whatsapp_verify_token

# ==============================
# External AI/Weather APIs
# ==============================
# Anthropic API key used for AI-assisted workflows.
ANTHROPIC_API_KEY=sk-ant-api03-example-key
# Weather API key for location-aware maintenance planning.
WEATHER_API_KEY=weatherapi_example_key_123456

# ==============================
# SMTP Mailer
# ==============================
# SMTP server host.
SMTP_HOST=smtp.mailtrap.io
# SMTP server port.
SMTP_PORT=587
# SMTP username.
SMTP_USER=maintainpro_smtp_user
# SMTP password.
SMTP_PASS=maintainpro_smtp_password
# Sender email displayed in outgoing messages.
SMTP_FROM=MaintainPro Alerts <alerts@maintainpro.local>
