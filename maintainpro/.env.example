NODE_ENV=development

# API runtime
PORT=3000
CORS_ORIGIN=http://localhost:3001
FRONTEND_URL=http://localhost:3001

# Frontend runtime
NEXT_PUBLIC_API_URL=http://localhost:3000/api
NEXT_PUBLIC_API_BASE_URL=http://localhost:3000/api
NEXT_PUBLIC_API_ORIGIN=http://localhost:3000
NEXT_PUBLIC_API_TIMEOUT_MS=60000

# Database and cache (Atlas primary, local MongoDB backup)
DATABASE_PROVIDER=mongodb
PRIMARY_DATABASE_URL=mongodb+srv://<username>:<password>@<atlas-host>/nelna?appName=Nelna
BACKUP_DATABASE_URL=mongodb://<username>:<url_encoded_password>@localhost:27017/bileeta_db?authSource=bileeta_db&replicaSet=rs0
DATABASE_URL=${PRIMARY_DATABASE_URL}
MONGODB_URI=${PRIMARY_DATABASE_URL}
PRIMARY_DATABASE_NAME=nelna
BACKUP_DATABASE_NAME=bileeta_db
DATABASE_SERVER_SELECTION_TIMEOUT_MS=5000
DATABASE_CONNECT_TIMEOUT_MS=5000
MONGO_DATABASE_NAME=nelna
MONGO_SYNC_ON_STARTUP=false
DATABASE_REPLICATION_ENABLED=true
DATABASE_REPLICATION_MODE=async_outbox
DATABASE_REPLICATION_RETRY_ATTEMPTS=5
DATABASE_REPLICATION_RETRY_DELAY_MS=5000
DATABASE_REPLICATION_BATCH_SIZE=100
BACKUP_DATABASE_REQUIRED_FOR_READINESS=false
BACKUP_DATABASE_REQUIRED_FOR_STRICT_MODE=true
REDIS_URL=redis://127.0.0.1:6379
REDIS_REQUIRED_FOR_READINESS=false
OBJECT_STORAGE_REQUIRED_FOR_READINESS=false

# Swagger (/api/docs) is always available outside production. In production it is
# disabled unless SWAGGER_ENABLED=true AND both SWAGGER_USER/SWAGGER_PASSWORD are set
# (used for HTTP Basic Auth on the docs route).
SWAGGER_ENABLED=false
# SWAGGER_USER=<set-if-enabling-swagger-in-production>
# SWAGGER_PASSWORD=<set-if-enabling-swagger-in-production>

# Detailed readiness (/health/readiness) requires an ADMIN/SUPER_ADMIN bearer token in
# production, or this shared key sent as the X-Readiness-Key header (for uptime/infra
# monitoring tools that cannot hold a JWT).
# READINESS_API_KEY=<set-for-infra-monitoring-in-production>

# Seed/smoke credentials must be supplied by the operator. Do not commit real values.
MAINTAINPRO_SEED_PASSWORD=<set-secure-seed-password>
MAINTAINPRO_SMOKE_EMAIL=<smoke-test-email>
MAINTAINPRO_SMOKE_PASSWORD=<smoke-test-password>

# Weather integration (OpenWeather API)
OPENWEATHER_API_KEY=
FARM_DEFAULT_LATITUDE=6.9271
FARM_DEFAULT_LONGITUDE=79.8612
WEATHER_ALERT_FROST_THRESHOLD_C=5
WEATHER_ALERT_RAIN_THRESHOLD_MM=50

# Public traceability portal
TRACEABILITY_PUBLIC_BASE_URL=https://trace.nelnafarm.lk

# Application metadata
APP_VERSION=1.2.0


# JWT auth
JWT_SECRET=replace_with_strong_shared_secret_or_leave_blank_if_using_split_secrets
JWT_ACCESS_SECRET=replace_with_strong_access_secret
JWT_REFRESH_SECRET=replace_with_strong_refresh_secret
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=7d

# When false (default), POST /auth/register requires a valid tenant invitation token.
# Set to true only for environments where open self-registration is desired.
ALLOW_PUBLIC_REGISTRATION=false

# Optional Stripe billing
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# Optional OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=http://localhost:3000/api/auth/google/callback
RAPIDAPI_GOOGLE_MAP_PLACES_KEY=

# Notification providers
SENDGRID_API_KEY=
SMTP_ENABLED=false
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=MaintainPro Alerts <alerts@maintainpro.local>
SMS_ENABLED=false
SMS_API_URL=
SMS_API_KEY=
SMS_API_SECRET=
SMS_AUTH_HEADER=Authorization
SMS_SENDER_ID=MaintainPro
# Staged notification UAT (NOTIFY-002) — disabled by default
NOTIFICATION_UAT_ENABLED=false
NOTIFICATION_REAL_SENDS_ENABLED=false
NOTIFICATION_UAT_ALLOWED_RECIPIENTS=
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# ERP and push providers
ERP_SYNC_PROVIDER=mock
ERP_SYNC_ALLOW_MOCK_IN_PRODUCTION=false
ERP_SYNC_REQUIRED_FOR_READINESS=false
ERP_PROVIDER_ID=
ERP_BASE_URL=
ERP_API_URL=
ERP_API_KEY=
ERP_AUTH_HEADER=Authorization
ERP_TIMEOUT_MS=15000
ERP_MODE=mock
# UAT-029 Bileeta integration readiness (default disabled — no live API calls)
ERP_SYNC_MODE=disabled
BILEETA_API_BASE_URL=
BILEETA_API_USERNAME=
BILEETA_API_PASSWORD=
BILEETA_API_KEY=
ERP_READ_ONLY_SYNC_ENABLED=false
ERP_STOCK_SYNC_APPLY_ENABLED=false
ERP_STOCK_ENDPOINT=
ERP_TENANT_CODE=
ERP_WAREHOUSE_CODE=
PUSH_PROVIDER=noop
PUSH_PROVIDER_ENABLED=false
PUSH_PROVIDER_API_URL=
PUSH_PROVIDER_API_KEY=
PUSH_PROVIDER_AUTH_HEADER=Authorization

# RapidAPI Copilot assistant
RAPIDAPI_COPILOT_API_KEY=
RAPIDAPI_COPILOT_HOST=copilot5.p.rapidapi.com

# Object storage (MinIO/S3 compatible)
STORAGE_MODE=local
STORAGE_UPLOADS_ENABLED=false
STORAGE_MAX_FILE_SIZE_MB=10
STORAGE_ALLOWED_MIME_TYPES=image/jpeg,image/png,image/webp,application/pdf
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
CLOUDINARY_ASSET_FOLDER=maintainpro/asset-documents
MINIO_ENDPOINT=localhost
MINIO_PORT=9000
MINIO_USE_SSL=false
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin123
MINIO_BUCKET=maintainpro-files

# Facility migration tooling (default false — see docs/FACILITY_LOCATION_BACKFILL_RUNBOOK.md)
ALLOW_FACILITY_BACKFILL_APPLY=false

# Duplicate facility issue detection window in days (1-90, default 7)
DUPLICATE_ISSUE_WINDOW_DAYS=7

# Vendor repair approval thresholds (LKR)
VENDOR_APPROVAL_SUPERVISOR_MAX=10000
VENDOR_APPROVAL_MANAGER_MAX=50000
VENDOR_APPROVAL_OPERATIONS_MAX=250000
VENDOR_HIGH_COST_QUOTATIONS_REQUIRED=2
