NODE_ENV=development

# API runtime
PORT=3000
CORS_ORIGIN=http://localhost:3001
FRONTEND_URL=http://localhost:3001

# Frontend runtime
NEXT_PUBLIC_API_BASE_URL=http://localhost:3000/api
NEXT_PUBLIC_API_ORIGIN=http://localhost:3000

# Database and cache (Nelna Farm Operations runs on MongoDB)
DATABASE_URL=mongodb://localhost:27018/nelna?replicaSet=rs0&directConnection=true
MONGODB_URI=mongodb://localhost:27018/nelna?replicaSet=rs0&directConnection=true
REDIS_URL=redis://localhost:6379

# Weather integration (OpenWeather API)
OPENWEATHER_API_KEY=
FARM_DEFAULT_LATITUDE=6.9271
FARM_DEFAULT_LONGITUDE=79.8612
WEATHER_ALERT_FROST_THRESHOLD_C=5
WEATHER_ALERT_RAIN_THRESHOLD_MM=50

# Public traceability portal
TRACEABILITY_PUBLIC_BASE_URL=https://trace.nelnafarm.lk

# Application metadata
APP_VERSION=1.2.0


# JWT auth
JWT_ACCESS_SECRET=replace_with_strong_access_secret
JWT_REFRESH_SECRET=replace_with_strong_refresh_secret
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=7d

# Optional Stripe billing
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# Optional OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=http://localhost:3000/api/auth/google/callback
RAPIDAPI_GOOGLE_MAP_PLACES_KEY=

# Notification providers
SENDGRID_API_KEY=
SMTP_HOST=smtp.mailtrap.io
SMTP_PORT=587
SMTP_USER=maintainpro_smtp_user
SMTP_PASS=maintainpro_smtp_password
SMTP_FROM=MaintainPro Alerts <alerts@maintainpro.local>
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# RapidAPI Copilot assistant
RAPIDAPI_COPILOT_API_KEY=
RAPIDAPI_COPILOT_HOST=copilot5.p.rapidapi.com

# Object storage (MinIO/S3 compatible)
MINIO_ENDPOINT=localhost
MINIO_PORT=9000
MINIO_USE_SSL=false
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin123
MINIO_BUCKET=maintainpro-files
