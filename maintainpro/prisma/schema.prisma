generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

model Tenant {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  name      String
  slug      String   @unique
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  memberships                  TenantMembership[]
  invitations                  TenantInvitation[]
  subscriptions                Subscription[]
  usageMetrics                 UsageMetric[]
  usageEvents                  UsageEvent[]
  stripeCustomer               StripeCustomer?
  stripeInvoices               StripeInvoice[]
  users                        User[]
  roles                        Role[]
  assets                       Asset[]
  vehicles                     Vehicle[]
  drivers                      Driver[]
  workOrders                   WorkOrder[]
  workOrderAssignees           WorkOrderAssignee[]
  employeeRosters              EmployeeRosterEntry[]
  employeeLeaveRequests        EmployeeLeaveRequest[]
  spareParts                   SparePart[]
  suppliers                    Supplier[]
  purchaseOrders               PurchaseOrder[]
  partRequests                 PartRequest[]
  partIssues                   PartIssue[]
  partRequestApprovals         PartRequestApproval[]
  workOrderParts               WorkOrderPart[]
  purchaseOrderApprovals       PurchaseOrderApproval[]
  purchaseOrderErpSyncAttempts PurchaseOrderErpSync[]
  purchaseOrderLines           PurchaseOrderLine[]
  meters                       UtilityMeter[]
  bills                        UtilityBill[]
  audits                       AuditLog[]
  cleaningLocations            CleaningLocation[]
  cleaningVisits               CleaningVisit[]
  facilityIssues               FacilityIssue[]
  properties                   Property[]
  buildings                    Building[]
  floors                       Floor[]
  rooms                        Room[]
  jobCodes                     JobCode[]
  departments                  Department[]
  vehicleDocuments             VehicleDocument[]
  accidentReports              AccidentReport[]
  insuranceClaims              InsuranceClaim[]
  trafficFines                 TrafficFine[]
  refreshTokens                RefreshToken[]
  evidenceAttachments          EvidenceAttachment[]
  employees                    Employee[]
  vendorRepairCases            VendorRepairCase[]
  vendorQuotations             VendorQuotation[]
  vendorInvoices               VendorInvoice[]
  workOrderTaxonomies          WorkOrderTaxonomy[]
}

model AuditLog {
  id            String      @id @default(auto()) @map("_id") @db.ObjectId
  tenantId      String?     @db.ObjectId
  tenant        Tenant?     @relation(fields: [tenantId], references: [id])
  entity        String
  entityId      String
  action        AuditAction
  module        String?
  reason        String?
  actorId       String?     @db.ObjectId
  actor         User?       @relation(fields: [actorId], references: [id])
  ipAddress     String?
  userAgent     String?
  requestPath   String?
  actorSnapshot Json?
  metadata      Json?
  beforeData    Json?
  afterData     Json?
  createdAt     DateTime    @default(now())

  @@index([entity, entityId])
  @@index([tenantId])
  @@index([tenantId, createdAt])
  @@index([tenantId, module, createdAt])
  @@index([actorId, createdAt])
}

model AppSetting {
  id        String          @id @default(auto()) @map("_id") @db.ObjectId
  scope     AppSettingScope @default(GLOBAL)
  scopeId   String          @default("GLOBAL")
  key       String
  value     Json
  isSecret  Boolean         @default(false)
  createdAt DateTime        @default(now())
  updatedAt DateTime        @updatedAt

  @@unique([scope, scopeId, key])
  @@index([key])
  @@index([scope, scopeId])
}

enum AppSettingScope {
  GLOBAL
  TENANT
  USER
}

enum AuditAction {
  CREATE
  UPDATE
  DELETE
}

enum ReplicationOperation {
  CREATE
  UPDATE
  UPSERT
  DELETE
}

enum ReplicationOutboxStatus {
  PENDING
  PROCESSING
  SYNCED
  FAILED
  DEAD_LETTER
}

model ReplicationOutbox {
  id             String                  @id @default(auto()) @map("_id") @db.ObjectId
  tenantId       String?                 @db.ObjectId
  entityType     String
  entityId       String
  operation      ReplicationOperation
  payload        Json?
  modelName      String
  status         ReplicationOutboxStatus @default(PENDING)
  attemptCount   Int                     @default(0)
  lastError      String?
  nextRetryAt    DateTime                @default(now())
  createdAt      DateTime                @default(now())
  updatedAt      DateTime                @updatedAt
  syncedAt       DateTime?
  sourceDatabase String                  @default("primary")
  targetDatabase String                  @default("backup")
  correlationId  String
  actorUserId    String?                 @db.ObjectId

  @@index([status, nextRetryAt])
  @@index([entityType, entityId])
  @@index([tenantId, status])
  @@index([createdAt])
  @@index([correlationId])
}

model Permission {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  key         String   @unique
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  roles   Role[]   @relation(fields: [roleIds], references: [id])
  roleIds String[] @db.ObjectId
}

model User {
  id                  String      @id @default(auto()) @map("_id") @db.ObjectId
  tenantId            String?     @db.ObjectId
  tenant              Tenant?     @relation(fields: [tenantId], references: [id])
  email               String      @unique
  passwordHash        String
  firstName           String
  lastName            String
  phone               String?
  avatar              String?
  roleId              String      @db.ObjectId
  role                Role        @relation(fields: [roleId], references: [id])
  /// FK to Department master — nullable for legacy records
  departmentId        String?     @db.ObjectId
  department          Department? @relation("UserDepartment", fields: [departmentId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  /// Job designation for workforce allocation (e.g. Electrician, Fitter)
  designation         String?
  /// Daily capacity in hours for workload checks (default 8)
  dailyCapacityHours  Float       @default(8)
  /// Skill tags for assignment filtering
  skills              String[]
  isActive            Boolean     @default(true)
  lastLogin           DateTime?
  failedLoginAttempts Int         @default(0)
  lockedUntil         DateTime?
  createdAt           DateTime    @default(now())
  updatedAt           DateTime    @updatedAt

  assignedWorkOrders          WorkOrder[]             @relation("TechnicianWorkOrders")
  createdWorkOrders           WorkOrder[]             @relation("CreatorWorkOrders")
  approvedWorkOrders          WorkOrder[]             @relation("ApprovedWorkOrders")
  verifiedWorkOrders          WorkOrder[]             @relation("VerifiedWorkOrders")
  reopenedWorkOrders          WorkOrder[]             @relation("ReopenedWorkOrders")
  qrVerifiedWorkOrders        WorkOrder[]             @relation("QrVerifiedWorkOrders")
  memberships                 TenantMembership[]
  sentInvitations             TenantInvitation[]      @relation("TenantInvitedBy")
  notifications               Notification[]
  auditEvents                 AuditLog[]
  driverProfile               Driver?
  cleaningVisits              CleaningVisit[]         @relation("CleanerVisits")
  signedOffVisits             CleaningVisit[]         @relation("SupervisorSignOffs")
  assignedCleaningLocations   CleaningLocation[]      @relation("AssignedCleaningLocations")
  reportedIssues              FacilityIssue[]         @relation("ReportedFacilityIssues")
  resolvedIssues              FacilityIssue[]         @relation("ResolvedFacilityIssues")
  assignedFacilityIssues      FacilityIssue[]         @relation("AssignedFacilityIssues")
  copilotConversations        CopilotConversation[]
  copilotMessages             CopilotMessage[]
  copilotExchangeLogs         CopilotExchangeLog[]
  managedDepartments          Department[]            @relation("DepartmentManager")
  recordedVehicleMeterLogs    VehicleMeterLog[]       @relation("VehicleMeterRecordedBy")
  approvedVehicleGateMoves    VehicleGateMovement[]   @relation("VehicleGateApprovedBy")
  partRequestsRequested       PartRequest[]           @relation("PartRequestRequester")
  partRequestApprovals        PartRequestApproval[]   @relation("PartRequestApprovalActor")
  partIssuesIssued            PartIssue[]             @relation("PartIssueIssuer")
  purchaseOrderApprovals      PurchaseOrderApproval[] @relation("PurchaseOrderApprovalActor")
  purchaseOrderErpSyncActions PurchaseOrderErpSync[]  @relation("PurchaseOrderErpSyncTrigger")
  vehicleDocsUploaded         VehicleDocument[]       @relation("VehicleDocUploader")
  vehicleDocsVerified         VehicleDocument[]       @relation("VehicleDocVerifier")
  accidentsReported           AccidentReport[]        @relation("AccidentReporter")
  accidentEvidenceUploaded    AccidentEvidence[]      @relation("AccidentEvidenceUploader")
  insuranceClaimsFiled        InsuranceClaim[]        @relation("InsuranceClaimFiler")
  trafficFinesReported        TrafficFine[]           @relation("TrafficFineReporter")
  refreshTokens               RefreshToken[]
  passwordResetTokens         PasswordResetToken[]
  evidenceAttachmentsUploaded EvidenceAttachment[]    @relation("EvidenceUploader")
  workOrderAssignmentsCreated WorkOrderAssignee[]     @relation("WorkOrderAssigneeAssignedBy")
  employeeLeaveApprovals      EmployeeLeaveRequest[]  @relation("EmployeeLeaveApprover")
  linkedWorkforceEmployees    Employee[]              @relation("EmployeeLinkedUser")

  @@index([tenantId])
  @@index([roleId])
  @@index([departmentId])
  @@index([designation])
}

model RefreshToken {
  id         String    @id @default(auto()) @map("_id") @db.ObjectId
  tokenHash  String    @unique
  userId     String    @db.ObjectId
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  tenantId   String?   @db.ObjectId
  tenant     Tenant?   @relation(fields: [tenantId], references: [id])
  deviceInfo String?
  ipAddress  String?
  userAgent  String?
  expiresAt  DateTime
  revokedAt  DateTime?
  lastUsedAt DateTime?
  createdAt  DateTime  @default(now())

  @@index([userId, createdAt])
  @@index([tenantId, createdAt])
  @@index([expiresAt])
  @@index([revokedAt])
}

model PasswordResetToken {
  id        String    @id @default(auto()) @map("_id") @db.ObjectId
  tokenHash String    @unique
  userId    String    @db.ObjectId
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  usedAt    DateTime?
  ipAddress String?
  createdAt DateTime  @default(now())

  @@index([userId, createdAt])
  @@index([expiresAt])
  @@index([usedAt])
}

model Role {
  id            String       @id @default(auto()) @map("_id") @db.ObjectId
  tenantId      String?      @db.ObjectId
  tenant        Tenant?      @relation(fields: [tenantId], references: [id])
  name          RoleName
  permissions   Permission[] @relation(fields: [permissionIds], references: [id])
  permissionIds String[]     @db.ObjectId
  users         User[]
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt

  @@index([tenantId, name])
  @@index([tenantId])
}

enum RoleName {
  SUPER_ADMIN
  ADMIN
  OPERATIONS_MANAGER
  FLEET_MANAGER
  COMPLIANCE_MANAGER
  MANAGER
  TECHNICIAN
  MECHANIC
  ASSET_MANAGER
  INVENTORY_KEEPER
  SUPERVISOR
  SECURITY_OFFICER
  CLEANER
  DRIVER
  VIEWER
  FARM_OWNER
  FARM_MANAGER
  FIELD_SUPERVISOR
  AGRONOMIST
  VETERINARIAN
  FARM_WORKER
  IRRIGATION_OPERATOR
  HARVEST_CREW
  FACILITY_MANAGER
  BUILDING_SUPERVISOR
}

model TenantMembership {
  id             String               @id @default(auto()) @map("_id") @db.ObjectId
  tenantId       String               @db.ObjectId
  tenant         Tenant               @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  userId         String               @db.ObjectId
  user           User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  membershipRole TenantMembershipRole @default(MEMBER)
  joinedAt       DateTime             @default(now())
  createdAt      DateTime             @default(now())
  updatedAt      DateTime             @updatedAt

  @@unique([tenantId, userId])
  @@index([userId])
  @@index([tenantId, membershipRole])
}

enum TenantMembershipRole {
  OWNER
  ADMIN
  MEMBER
  BILLING
}

model TenantInvitation {
  id             String                 @id @default(auto()) @map("_id") @db.ObjectId
  tenantId       String                 @db.ObjectId
  tenant         Tenant                 @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  email          String
  firstName      String?
  lastName       String?
  membershipRole TenantMembershipRole   @default(MEMBER)
  invitedById    String                 @db.ObjectId
  invitedBy      User                   @relation("TenantInvitedBy", fields: [invitedById], references: [id], onDelete: Cascade)
  token          String                 @unique
  status         TenantInvitationStatus @default(PENDING)
  expiresAt      DateTime
  acceptedAt     DateTime?
  createdAt      DateTime               @default(now())
  updatedAt      DateTime               @updatedAt

  @@index([tenantId, email])
  @@index([invitedById])
  @@index([status, expiresAt])
}

enum TenantInvitationStatus {
  PENDING
  ACCEPTED
  EXPIRED
  REVOKED
}

model Plan {
  id            String         @id @default(auto()) @map("_id") @db.ObjectId
  code          String         @unique
  name          String
  description   String?
  isActive      Boolean        @default(true)
  currency      String         @default("USD")
  priceMonthly  Float          @default(0)
  priceYearly   Float          @default(0)
  metadata      Json?
  entitlements  Entitlement[]
  subscriptions Subscription[]
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
}

model Subscription {
  id                   String             @id @default(auto()) @map("_id") @db.ObjectId
  tenantId             String             @db.ObjectId
  tenant               Tenant             @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  planId               String             @db.ObjectId
  plan                 Plan               @relation(fields: [planId], references: [id])
  status               SubscriptionStatus @default(TRIALING)
  billingInterval      BillingInterval    @default(MONTHLY)
  seats                Int                @default(5)
  isCurrent            Boolean            @default(true)
  startedAt            DateTime           @default(now())
  currentPeriodStart   DateTime           @default(now())
  currentPeriodEnd     DateTime?
  cancelAtPeriodEnd    Boolean            @default(false)
  canceledAt           DateTime?
  stripeSubscriptionId String?            @unique
  stripePriceId        String?
  invoices             StripeInvoice[]
  createdAt            DateTime           @default(now())
  updatedAt            DateTime           @updatedAt

  @@index([tenantId, isCurrent])
  @@index([status])
  @@index([planId])
}

enum SubscriptionStatus {
  TRIALING
  ACTIVE
  PAST_DUE
  CANCELED
  INCOMPLETE
  PAUSED
}

enum BillingInterval {
  MONTHLY
  YEARLY
}

model Entitlement {
  id          String          @id @default(auto()) @map("_id") @db.ObjectId
  planId      String          @db.ObjectId
  plan        Plan            @relation(fields: [planId], references: [id], onDelete: Cascade)
  key         String
  type        EntitlementType @default(FEATURE)
  enabled     Boolean         @default(true)
  limitValue  Int?
  unit        String?
  overageRate Float?
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  @@unique([planId, key])
  @@index([key])
}

enum EntitlementType {
  FEATURE
  LIMIT
}

model UsageMetric {
  id          String            @id @default(auto()) @map("_id") @db.ObjectId
  tenantId    String            @db.ObjectId
  tenant      Tenant            @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  key         String
  window      UsageMetricWindow @default(MONTHLY)
  periodStart DateTime
  periodEnd   DateTime
  value       Int               @default(0)
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt

  @@unique([tenantId, key, window, periodStart])
  @@index([tenantId, periodEnd])
}

enum UsageMetricWindow {
  DAILY
  MONTHLY
}

model UsageEvent {
  id         String         @id @default(auto()) @map("_id") @db.ObjectId
  tenantId   String         @db.ObjectId
  tenant     Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  key        String
  eventType  UsageEventType @default(CONSUME)
  quantity   Int            @default(1)
  metadata   Json?
  occurredAt DateTime       @default(now())

  @@index([tenantId, key, occurredAt])
}

enum UsageEventType {
  CONSUME
  CREDIT
  RESET
}

model StripeCustomer {
  id         String   @id @default(auto()) @map("_id") @db.ObjectId
  tenantId   String   @unique @db.ObjectId
  tenant     Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  customerId String   @unique
  email      String?
  name       String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model StripeInvoice {
  id               String        @id @default(auto()) @map("_id") @db.ObjectId
  tenantId         String        @db.ObjectId
  tenant           Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  subscriptionId   String?       @db.ObjectId
  subscription     Subscription? @relation(fields: [subscriptionId], references: [id], onDelete: SetNull)
  stripeInvoiceId  String        @unique
  invoiceNumber    String?
  amountDue        Float         @default(0)
  amountPaid       Float         @default(0)
  currency         String        @default("usd")
  status           String
  hostedInvoiceUrl String?
  invoicePdf       String?
  dueDate          DateTime?
  paidAt           DateTime?
  periodStart      DateTime?
  periodEnd        DateTime?
  raw              Json?
  createdAt        DateTime      @default(now())

  @@index([tenantId, createdAt])
  @@index([subscriptionId])
}

// ─── Department Master ──────────────────────────────────────────────────────
model Department {
  id          String       @id @default(auto()) @map("_id") @db.ObjectId
  tenantId    String?      @db.ObjectId
  tenant      Tenant?      @relation(fields: [tenantId], references: [id])
  name        String
  code        String
  description String?
  isActive    Boolean      @default(true)
  /// Self-FK for hierarchical departments (parent org unit)
  parentId    String?      @db.ObjectId
  parent      Department?  @relation("DeptChildren", fields: [parentId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  children    Department[] @relation("DeptChildren")
  /// Optional FK to User who manages this department
  managerId   String?      @db.ObjectId
  manager     User?        @relation("DepartmentManager", fields: [managerId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  assets    Asset[]    @relation("AssetDepartment")
  vehicles  Vehicle[]  @relation("VehicleDepartment")
  drivers   Driver[]   @relation("DriverDepartment")
  users     User[]     @relation("UserDepartment")
  employees Employee[] @relation("EmployeeDepartment")

  @@unique([tenantId, code])
  @@index([tenantId, isActive])
  @@index([tenantId, parentId])
  @@index([managerId])
}

model Asset {
  id              String         @id @default(auto()) @map("_id") @db.ObjectId
  tenantId        String?        @db.ObjectId
  tenant          Tenant?        @relation(fields: [tenantId], references: [id])
  assetTag        String         @unique
  name            String
  description     String?
  category        AssetCategory
  condition       AssetCondition @default(GOOD)
  status          AssetStatus    @default(ACTIVE)
  purchaseDate    DateTime?
  purchasePrice   Float?
  supplier        String?
  /// Legacy free-text department — preserved for historical accuracy
  department      String?
  /// FK to Department master — nullable for legacy records
  departmentId    String?        @db.ObjectId
  departmentRef   Department?    @relation("AssetDepartment", fields: [departmentId], references: [id])
  ownerName       String?
  currentValue    Float?
  location        String?
  manufacturer    String?
  model           String?
  serialNumber    String?
  meterReading    Float?
  lastServiceDate DateTime?
  nextServiceDate DateTime?
  warrantyExpiry  DateTime?
  disposalDate    DateTime?
  disposalReason  String?
  archivedAt      DateTime?
  images          String[]
  documents       String[]
  qrCodeUrl       String?
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  maintenanceLogs      MaintenanceLog[]
  maintenanceSchedules MaintenanceSchedule[]
  workOrders           WorkOrder[]
  predictiveLogs       PredictiveLog[]

  @@index([tenantId])
  @@index([status])
  @@index([category])
  @@index([condition])
  @@index([archivedAt])
  @@index([nextServiceDate])
  @@index([departmentId])
}

enum AssetStatus {
  ACTIVE
  INACTIVE
  UNDER_MAINTENANCE
  DISPOSED
  RETIRED
}

enum AssetCategory {
  MACHINE
  TOOL
  INFRASTRUCTURE
  EQUIPMENT
  VEHICLE
  OTHER
  TRACTOR
  HARVESTER
  SPRAYER
  IRRIGATION_PUMP
  IRRIGATION_PIPE
  GREENHOUSE
  BARN
  STORAGE_SILO
  COLD_ROOM
  MILKING_MACHINE
}

enum AssetCondition {
  EXCELLENT
  GOOD
  FAIR
  POOR
  CRITICAL
}

model Vehicle {
  id                        String               @id @default(auto()) @map("_id") @db.ObjectId
  tenantId                  String?              @db.ObjectId
  tenant                    Tenant?              @relation(fields: [tenantId], references: [id])
  registrationNo            String               @unique
  assetTag                  String?
  make                      String
  vehicleModel              String
  description               String?
  location                  String?
  year                      Int
  type                      VehicleType
  ownershipType             VehicleOwnershipType @default(OWNED)
  status                    VehicleStatus        @default(AVAILABLE)
  serviceStatus             VehicleServiceStatus @default(ON_SCHEDULE)
  color                     String?
  vin                       String?              @unique
  engineNo                  String?
  vendorName                String?
  costCenter                String?
  acquisitionDate           DateTime?
  purchasePrice             Float?
  currentValue              Float?
  warrantyExpiry            DateTime?
  fuelType                  FuelType
  fuelCapacity              Float?
  currentMileage            Float                @default(0)
  serviceIntervalDays       Int?
  serviceIntervalMileage    Float?
  insuranceExpiry           DateTime?
  roadTaxExpiry             DateTime?
  complianceStatus          ComplianceStatus     @default(COMPLIANT)
  complianceLastEvaluatedAt DateTime?
  lastServiceDate           DateTime?
  nextServiceDate           DateTime?
  nextServiceMileage        Float?
  decommissionedAt          DateTime?
  decommissionReason        String?
  customFields              Json?
  gpsDeviceId               String?
  images                    String[]
  driverId                  String?              @db.ObjectId
  driver                    Driver?              @relation(fields: [driverId], references: [id])
  /// FK to Department master — nullable for legacy records
  departmentId              String?              @db.ObjectId
  department                Department?          @relation("VehicleDepartment", fields: [departmentId], references: [id])
  createdAt                 DateTime             @default(now())
  updatedAt                 DateTime             @updatedAt

  fuelLogs             FuelLog[]
  tripLogs             TripLog[]
  maintenanceSchedules MaintenanceSchedule[]
  maintenanceLogs      MaintenanceLog[]
  workOrders           WorkOrder[]
  gpsLocations         GpsLocation[]
  meterLogs            VehicleMeterLog[]
  gateMovements        VehicleGateMovement[]
  documents            VehicleDocument[]
  accidents            AccidentReport[]
  insuranceClaims      InsuranceClaim[]
  trafficFines         TrafficFine[]

  @@index([tenantId])
  @@index([status])
  @@index([driverId])
  @@index([location])
  @@index([type])
  @@index([departmentId])
  @@index([serviceStatus])
  @@index([assetTag])
  @@index([costCenter])
  @@index([tenantId, status, nextServiceDate])
}

enum VehicleType {
  CAR
  MOTORCYCLE
  TRUCK
  VAN
  BUS
  HEAVY_EQUIPMENT
  OTHER
}

enum VehicleStatus {
  AVAILABLE
  IN_USE
  UNDER_MAINTENANCE
  OUT_OF_SERVICE
  DISPOSED
}

enum VehicleOwnershipType {
  OWNED
  LEASED
  RENTED
  THIRD_PARTY
}

enum VehicleServiceStatus {
  ON_SCHEDULE
  DUE_SOON
  OVERDUE
}

enum FuelType {
  PETROL
  DIESEL
  ELECTRIC
  HYBRID
  CNG
  LPG
}

enum DriverTrainingStatus {
  NOT_STARTED
  IN_PROGRESS
  CURRENT
  EXPIRED
}

model Driver {
  id                        String               @id @default(auto()) @map("_id") @db.ObjectId
  tenantId                  String?              @db.ObjectId
  tenant                    Tenant?              @relation(fields: [tenantId], references: [id])
  userId                    String               @unique @db.ObjectId
  user                      User                 @relation(fields: [userId], references: [id])
  licenseNumber             String               @unique
  licenseClass              String
  licenseExpiry             DateTime
  isAvailable               Boolean              @default(true)
  trainingStatus            DriverTrainingStatus @default(NOT_STARTED)
  trainingCompletedAt       DateTime?
  trainingExpiry            DateTime?
  supervisorReviewScore     Int?
  pendingDisciplinaryIssues Int                  @default(0)
  /// FK to Department master — nullable for legacy records
  departmentId              String?              @db.ObjectId
  department                Department?          @relation("DriverDepartment", fields: [departmentId], references: [id])
  createdAt                 DateTime             @default(now())
  updatedAt                 DateTime             @updatedAt

  vehicles      Vehicle[]
  fuelLogs      FuelLog[]
  tripLogs      TripLog[]
  gateMovements VehicleGateMovement[]
  accidents     AccidentReport[]
  trafficFines  TrafficFine[]

  @@index([tenantId])
  @@index([departmentId])
}

model FuelLog {
