generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Tenant {
  id         String       @id @default(cuid())
  name       String
  slug       String       @unique
  isActive   Boolean      @default(true)
  createdAt  DateTime     @default(now())
  updatedAt  DateTime     @updatedAt

  memberships TenantMembership[]
  invitations TenantInvitation[]
  subscriptions Subscription[]
  usageMetrics UsageMetric[]
  usageEvents  UsageEvent[]
  stripeCustomer StripeCustomer?
  stripeInvoices StripeInvoice[]

  users      User[]
  roles      Role[]
  assets     Asset[]
  vehicles   Vehicle[]
  drivers    Driver[]
  workOrders WorkOrder[]
  spareParts SparePart[]
  suppliers  Supplier[]
  meters     UtilityMeter[]
  bills      UtilityBill[]
  audits     AuditLog[]
  cleaningLocations CleaningLocation[]
  cleaningVisits    CleaningVisit[]
  facilityIssues    FacilityIssue[]
}

model AuditLog {
  id         String   @id @default(cuid())
  tenantId   String?
  tenant     Tenant?  @relation(fields: [tenantId], references: [id])
  entity     String
  entityId   String
  action     AuditAction
  actorId    String?
  actor      User?    @relation(fields: [actorId], references: [id])
  beforeData Json?
  afterData  Json?
  createdAt  DateTime @default(now())

  @@index([entity, entityId])
  @@index([tenantId])
}

model AppSetting {
  id         String          @id @default(cuid())
  scope      AppSettingScope @default(GLOBAL)
  scopeId    String          @default("GLOBAL")
  key        String
  value      Json
  isSecret   Boolean         @default(false)
  createdAt  DateTime        @default(now())
  updatedAt  DateTime        @updatedAt

  @@unique([scope, scopeId, key])
  @@index([key])
  @@index([scope, scopeId])
}

enum AppSettingScope {
  GLOBAL
  TENANT
  USER
}

enum AuditAction {
  CREATE
  UPDATE
  DELETE
}

model Permission {
  id          String   @id @default(cuid())
  key         String   @unique
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  roles       Role[]
}

model User {
  id                 String         @id @default(cuid())
  tenantId           String?
  tenant             Tenant?        @relation(fields: [tenantId], references: [id])
  email              String         @unique
  passwordHash       String
  firstName          String
  lastName           String
  phone              String?
  avatar             String?
  roleId             String
  role               Role           @relation(fields: [roleId], references: [id])
  isActive           Boolean        @default(true)
  lastLogin          DateTime?
  createdAt          DateTime       @default(now())
  updatedAt          DateTime       @updatedAt

  assignedWorkOrders WorkOrder[]    @relation("TechnicianWorkOrders")
  createdWorkOrders  WorkOrder[]    @relation("CreatorWorkOrders")
  memberships        TenantMembership[]
  sentInvitations    TenantInvitation[] @relation("TenantInvitedBy")
  notifications      Notification[]
  auditEvents        AuditLog[]
  driverProfile      Driver?
  cleaningVisits     CleaningVisit[]   @relation("CleanerVisits")
  signedOffVisits    CleaningVisit[]   @relation("SupervisorSignOffs")
  assignedCleaningLocations CleaningLocation[] @relation("AssignedCleaningLocations")
  reportedIssues     FacilityIssue[]   @relation("ReportedFacilityIssues")
  resolvedIssues     FacilityIssue[]   @relation("ResolvedFacilityIssues")
  assignedFacilityIssues FacilityIssue[] @relation("AssignedFacilityIssues")
  copilotConversations CopilotConversation[]
  copilotMessages      CopilotMessage[]
  copilotExchangeLogs  CopilotExchangeLog[]

  @@index([tenantId])
  @@index([roleId])
}

model Role {
  id          String       @id @default(cuid())
  tenantId    String?
  tenant      Tenant?      @relation(fields: [tenantId], references: [id])
  name        RoleName
  permissions Permission[]
  users       User[]
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  @@unique([tenantId, name])
  @@index([tenantId])
}

enum RoleName {
  SUPER_ADMIN
  ADMIN
  MANAGER
  TECHNICIAN
  MECHANIC
  ASSET_MANAGER
  INVENTORY_KEEPER
  SUPERVISOR
  CLEANER
  DRIVER
  VIEWER
}

model TenantMembership {
  id             String               @id @default(cuid())
  tenantId       String
  tenant         Tenant               @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  userId         String
  user           User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  membershipRole TenantMembershipRole @default(MEMBER)
  joinedAt       DateTime             @default(now())
  createdAt      DateTime             @default(now())
  updatedAt      DateTime             @updatedAt

  @@unique([tenantId, userId])
  @@index([userId])
  @@index([tenantId, membershipRole])
}

enum TenantMembershipRole {
  OWNER
  ADMIN
  MEMBER
  BILLING
}

model TenantInvitation {
  id             String                 @id @default(cuid())
  tenantId       String
  tenant         Tenant                 @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  email          String
  firstName      String?
  lastName       String?
  membershipRole TenantMembershipRole   @default(MEMBER)
  invitedById    String
  invitedBy      User                   @relation("TenantInvitedBy", fields: [invitedById], references: [id], onDelete: Cascade)
  token          String                 @unique
  status         TenantInvitationStatus @default(PENDING)
  expiresAt      DateTime
  acceptedAt     DateTime?
  createdAt      DateTime               @default(now())
  updatedAt      DateTime               @updatedAt

  @@index([tenantId, email])
  @@index([invitedById])
  @@index([status, expiresAt])
}

enum TenantInvitationStatus {
  PENDING
  ACCEPTED
  EXPIRED
  REVOKED
}

model Plan {
  id            String        @id @default(cuid())
  code          String        @unique
  name          String
  description   String?
  isActive      Boolean       @default(true)
  currency      String        @default("USD")
  priceMonthly  Decimal       @default(0)
  priceYearly   Decimal       @default(0)
  metadata      Json?
  entitlements  Entitlement[]
  subscriptions Subscription[]
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
}

model Subscription {
  id                   String             @id @default(cuid())
  tenantId             String
  tenant               Tenant             @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  planId               String
  plan                 Plan               @relation(fields: [planId], references: [id])
  status               SubscriptionStatus @default(TRIALING)
  billingInterval      BillingInterval    @default(MONTHLY)
  seats                Int                @default(5)
  isCurrent            Boolean            @default(true)
  startedAt            DateTime           @default(now())
  currentPeriodStart   DateTime           @default(now())
  currentPeriodEnd     DateTime?
  cancelAtPeriodEnd    Boolean            @default(false)
  canceledAt           DateTime?
  stripeSubscriptionId String?            @unique
  stripePriceId        String?
  invoices             StripeInvoice[]
  createdAt            DateTime           @default(now())
  updatedAt            DateTime           @updatedAt

  @@index([tenantId, isCurrent])
  @@index([status])
  @@index([planId])
}

enum SubscriptionStatus {
  TRIALING
  ACTIVE
  PAST_DUE
  CANCELED
  INCOMPLETE
  PAUSED
}

enum BillingInterval {
  MONTHLY
  YEARLY
}

model Entitlement {
  id          String          @id @default(cuid())
  planId      String
  plan        Plan            @relation(fields: [planId], references: [id], onDelete: Cascade)
  key         String
  type        EntitlementType @default(FEATURE)
  enabled     Boolean         @default(true)
  limitValue  Int?
  unit        String?
  overageRate Decimal?
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  @@unique([planId, key])
  @@index([key])
}

enum EntitlementType {
  FEATURE
  LIMIT
}

model UsageMetric {
  id          String            @id @default(cuid())
  tenantId    String
  tenant      Tenant            @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  key         String
  window      UsageMetricWindow @default(MONTHLY)
  periodStart DateTime
  periodEnd   DateTime
  value       Int               @default(0)
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt

  @@unique([tenantId, key, window, periodStart])
  @@index([tenantId, periodEnd])
}

enum UsageMetricWindow {
  DAILY
  MONTHLY
}

model UsageEvent {
  id        String         @id @default(cuid())
  tenantId  String
  tenant    Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  key       String
  eventType UsageEventType @default(CONSUME)
  quantity  Int            @default(1)
  metadata  Json?
  occurredAt DateTime      @default(now())

  @@index([tenantId, key, occurredAt])
}

enum UsageEventType {
  CONSUME
  CREDIT
  RESET
}

model StripeCustomer {
  id         String   @id @default(cuid())
  tenantId   String   @unique
  tenant     Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  customerId String   @unique
  email      String?
  name       String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model StripeInvoice {
  id              String        @id @default(cuid())
  tenantId        String
  tenant          Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  subscriptionId  String?
  subscription    Subscription? @relation(fields: [subscriptionId], references: [id], onDelete: SetNull)
  stripeInvoiceId String        @unique
  invoiceNumber   String?
  amountDue       Decimal       @default(0)
  amountPaid      Decimal       @default(0)
  currency        String        @default("usd")
  status          String
  hostedInvoiceUrl String?
  invoicePdf      String?
  dueDate         DateTime?
  paidAt          DateTime?
  periodStart     DateTime?
  periodEnd       DateTime?
  raw             Json?
  createdAt       DateTime      @default(now())

  @@index([tenantId, createdAt])
  @@index([subscriptionId])
}

model Asset {
  id               String          @id @default(cuid())
  tenantId         String?
  tenant           Tenant?         @relation(fields: [tenantId], references: [id])
  assetTag         String          @unique
  name             String
  description      String?
  category         AssetCategory
  condition        AssetCondition  @default(GOOD)
  status           AssetStatus     @default(ACTIVE)
  purchaseDate     DateTime?
  purchasePrice    Decimal?
  supplier         String?
  department       String?
  ownerName        String?
  currentValue     Decimal?
  location         String?
  manufacturer     String?
  model            String?
  serialNumber     String?
  meterReading     Decimal?
  lastServiceDate  DateTime?
  nextServiceDate  DateTime?
  warrantyExpiry   DateTime?
  disposalDate     DateTime?
  disposalReason   String?
  archivedAt       DateTime?
  images           String[]
  documents        String[]
  qrCodeUrl        String?
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt

  maintenanceLogs  MaintenanceLog[]
  maintenanceSchedules MaintenanceSchedule[]
  workOrders       WorkOrder[]
  predictiveLogs   PredictiveLog[]

  @@index([tenantId])
  @@index([status])
  @@index([category])
  @@index([condition])
  @@index([archivedAt])
  @@index([nextServiceDate])
}

enum AssetStatus {
  ACTIVE
  INACTIVE
  UNDER_MAINTENANCE
  DISPOSED
  RETIRED
}

enum AssetCategory {
  MACHINE
  TOOL
  INFRASTRUCTURE
  EQUIPMENT
  VEHICLE
  OTHER
}

enum AssetCondition {
  EXCELLENT
  GOOD
  FAIR
  POOR
  CRITICAL
}

model Vehicle {
  id                  String            @id @default(cuid())
  tenantId            String?
  tenant              Tenant?           @relation(fields: [tenantId], references: [id])
  registrationNo      String            @unique
  make                String
  vehicleModel        String
  year                Int
  type                VehicleType
  status              VehicleStatus     @default(AVAILABLE)
  color               String?
  vin                 String?           @unique
  engineNo            String?
  fuelType            FuelType
  fuelCapacity        Decimal?
  currentMileage      Decimal           @default(0)
  insuranceExpiry     DateTime?
  roadTaxExpiry       DateTime?
  lastServiceDate     DateTime?
  nextServiceDate     DateTime?
  nextServiceMileage  Decimal?
  gpsDeviceId         String?
  images              String[]
  driverId            String?
  driver              Driver?           @relation(fields: [driverId], references: [id])
  createdAt           DateTime          @default(now())
  updatedAt           DateTime          @updatedAt

  fuelLogs            FuelLog[]
  tripLogs            TripLog[]
  maintenanceSchedules MaintenanceSchedule[]
  maintenanceLogs     MaintenanceLog[]
  workOrders          WorkOrder[]
  gpsLocations        GpsLocation[]

  @@index([tenantId])
  @@index([status])
  @@index([driverId])
}

enum VehicleType {
  CAR
  MOTORCYCLE
  TRUCK
  VAN
  BUS
  HEAVY_EQUIPMENT
  OTHER
}

enum VehicleStatus {
  AVAILABLE
  IN_USE
  UNDER_MAINTENANCE
  OUT_OF_SERVICE
  DISPOSED
}

enum FuelType {
  PETROL
  DIESEL
  ELECTRIC
  HYBRID
  CNG
  LPG
}

model Driver {
  id             String     @id @default(cuid())
  tenantId       String?
  tenant         Tenant?    @relation(fields: [tenantId], references: [id])
  userId         String     @unique
  user           User       @relation(fields: [userId], references: [id])
  licenseNumber  String     @unique
  licenseClass   String
  licenseExpiry  DateTime
  isAvailable    Boolean    @default(true)
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt

  vehicles       Vehicle[]
  tripLogs       TripLog[]

  @@index([tenantId])
}

model FuelLog {
  id            String    @id @default(cuid())
  vehicleId     String
  vehicle       Vehicle   @relation(fields: [vehicleId], references: [id])
  date          DateTime
  liters        Decimal
  costPerLiter  Decimal
  totalCost     Decimal
  mileageAtFuel Decimal
  fuelStation   String?
  receiptUrl    String?
  notes         String?
  createdAt     DateTime  @default(now())

  @@index([vehicleId, date])
}

model TripLog {
  id            String      @id @default(cuid())
  vehicleId     String
  vehicle       Vehicle     @relation(fields: [vehicleId], references: [id])
  driverId      String
  driver        Driver      @relation(fields: [driverId], references: [id])
  startLocation String
  endLocation   String
  startMileage  Decimal
  endMileage    Decimal
  distance      Decimal
  startTime     DateTime
  endTime       DateTime?
  purpose       String?
  status        TripStatus  @default(IN_PROGRESS)
  notes         String?
  createdAt     DateTime    @default(now())

  @@index([vehicleId, startTime])
  @@index([driverId, startTime])
}

enum TripStatus {
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

model GpsLocation {
  id          String    @id @default(cuid())
  vehicleId   String
  vehicle     Vehicle   @relation(fields: [vehicleId], references: [id])
  latitude    Decimal
  longitude   Decimal
  speed       Decimal?
  heading     Decimal?
  timestamp   DateTime  @default(now())

  @@index([vehicleId, timestamp])
}

model MaintenanceSchedule {
  id              String                @id @default(cuid())
  name            String
  description     String?
  type            MaintenanceType
  frequency       MaintenanceFrequency
  intervalDays    Int?
  intervalMileage Decimal?
  assetId         String?
  asset           Asset?                @relation(fields: [assetId], references: [id])
  vehicleId       String?
  vehicle         Vehicle?              @relation(fields: [vehicleId], references: [id])
  nextDueDate     DateTime?
  nextDueMileage  Decimal?
  isActive        Boolean               @default(true)
  estimatedCost   Decimal?
  estimatedHours  Decimal?
  createdAt       DateTime              @default(now())
  updatedAt       DateTime              @updatedAt

  maintenanceLogs MaintenanceLog[]
  workOrders      WorkOrder[]

  @@index([assetId])
  @@index([vehicleId])
  @@index([nextDueDate])
}

enum MaintenanceType {
  PREVENTIVE
  PREDICTIVE
  CORRECTIVE
  INSPECTION
}

enum MaintenanceFrequency {
  DAILY
  WEEKLY
  MONTHLY
  QUARTERLY
  BIANNUAL
  ANNUAL
  MILEAGE_BASED
  CUSTOM
}

model MaintenanceLog {
  id            String               @id @default(cuid())
  scheduleId    String?
  schedule      MaintenanceSchedule? @relation(fields: [scheduleId], references: [id])
  assetId       String?
  asset         Asset?               @relation(fields: [assetId], references: [id])
  vehicleId     String?
  vehicle       Vehicle?             @relation(fields: [vehicleId], references: [id])
  workOrderId   String?
  workOrder     WorkOrder?           @relation(fields: [workOrderId], references: [id])
  description   String
  performedBy   String
  performedAt   DateTime
  cost          Decimal?
  notes         String?
  attachments   String[]
  createdAt     DateTime             @default(now())

  @@index([scheduleId])
  @@index([assetId])
  @@index([vehicleId])
  @@index([performedAt])
}

model WorkOrder {
  id              String          @id @default(cuid())
  tenantId        String?
  tenant          Tenant?         @relation(fields: [tenantId], references: [id])
  woNumber        String          @unique
  title           String
  description     String
  priority        Priority        @default(MEDIUM)
  status          WorkOrderStatus @default(OPEN)
  type            WorkOrderType
  assetId         String?
  asset           Asset?          @relation(fields: [assetId], references: [id])
  vehicleId       String?
  vehicle         Vehicle?        @relation(fields: [vehicleId], references: [id])
  scheduleId      String?
  schedule        MaintenanceSchedule? @relation(fields: [scheduleId], references: [id])
  createdById     String
  createdBy       User            @relation("CreatorWorkOrders", fields: [createdById], references: [id])
  technicianId    String?
  technician      User?           @relation("TechnicianWorkOrders", fields: [technicianId], references: [id])
  dueDate         DateTime?
  startDate       DateTime?
  completedDate   DateTime?
  estimatedCost   Decimal?
  actualCost      Decimal?
  estimatedHours  Decimal?
  actualHours     Decimal?
  slaDeadline     DateTime?
  slaBreached     Boolean         @default(false)
  notes           String?
  attachments     String[]
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  maintenanceLogs MaintenanceLog[]
  parts           WorkOrderPart[]

  @@index([tenantId])
  @@index([status])
  @@index([priority])
  @@index([technicianId])
}

enum Priority {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum WorkOrderStatus {
  OPEN
  IN_PROGRESS
  ON_HOLD
  COMPLETED
  CANCELLED
  OVERDUE
}

enum WorkOrderType {
  PREVENTIVE
  CORRECTIVE
  EMERGENCY
  INSPECTION
  INSTALLATION
}

model SparePart {
  id              String          @id @default(cuid())
  tenantId        String?
  tenant          Tenant?         @relation(fields: [tenantId], references: [id])
  partNumber      String          @unique
  name            String
  description     String?
  category        String
  unit            String          @default("pcs")
  quantityInStock Int             @default(0)
  minimumStock    Int             @default(0)
  reorderPoint    Int             @default(0)
  unitCost        Decimal
  location        String?
  supplierId      String?
  supplier        Supplier?       @relation(fields: [supplierId], references: [id])
  images          String[]
  isActive        Boolean         @default(true)
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  stockMovements  StockMovement[]
  workOrderParts  WorkOrderPart[]

  @@index([tenantId])
  @@index([supplierId])
}

model StockMovement {
  id          String         @id @default(cuid())
  partId      String
  part        SparePart      @relation(fields: [partId], references: [id])
  type        MovementType
  quantity    Int
  reference   String?
  notes       String?
  createdAt   DateTime       @default(now())

  @@index([partId, createdAt])
}

enum MovementType {
  IN
  OUT
  ADJUSTMENT
  RETURN
}

model WorkOrderPart {
  id          String      @id @default(cuid())
  workOrderId String
  workOrder   WorkOrder   @relation(fields: [workOrderId], references: [id])
  partId      String
  part        SparePart   @relation(fields: [partId], references: [id])
  quantity    Int
  unitCost    Decimal
  totalCost   Decimal

  @@index([workOrderId])
  @@index([partId])
}

model Supplier {
  id            String         @id @default(cuid())
  tenantId      String?
  tenant        Tenant?        @relation(fields: [tenantId], references: [id])
  name          String
  contactName   String?
  email         String?
  phone         String?
  address       String?
  website       String?
  taxNumber     String?
  isActive      Boolean        @default(true)
  notes         String?
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  spareParts    SparePart[]
  purchaseOrders PurchaseOrder[]

  @@index([tenantId])
}

model PurchaseOrder {
  id           String    @id @default(cuid())
  poNumber     String    @unique
  supplierId   String
  supplier     Supplier  @relation(fields: [supplierId], references: [id])
  status       POStatus  @default(PENDING)
  orderDate    DateTime
  expectedDate DateTime?
  receivedDate DateTime?
  totalAmount  Decimal
  notes        String?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  @@index([supplierId])
}

enum POStatus {
  PENDING
  ORDERED
  PARTIALLY_RECEIVED
  RECEIVED
  CANCELLED
}

model UtilityMeter {
  id          String       @id @default(cuid())
  tenantId    String?
  tenant      Tenant?      @relation(fields: [tenantId], references: [id])
  meterNumber String       @unique
  type        UtilityType
  location    String
  description String?
  unit        String
  isActive    Boolean      @default(true)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  readings    MeterReading[]
  bills       UtilityBill[]

  @@index([tenantId])
}

enum UtilityType {
  ELECTRICITY
  WATER
  GAS
}

model MeterReading {
  id           String       @id @default(cuid())
  meterId       String
  meter         UtilityMeter @relation(fields: [meterId], references: [id])
  readingDate   DateTime
  readingValue  Decimal
  consumption   Decimal?
  images        String[]
  notes         String?
  createdAt     DateTime     @default(now())

  @@index([meterId, readingDate])
}

model UtilityBill {
  id                 String       @id @default(cuid())
  tenantId           String?
  tenant             Tenant?      @relation(fields: [tenantId], references: [id])
  meterId            String
  meter              UtilityMeter @relation(fields: [meterId], references: [id])
  billingPeriodStart DateTime
  billingPeriodEnd   DateTime
  totalConsumption   Decimal
  ratePerUnit        Decimal
  baseCharge         Decimal?
  taxAmount          Decimal?
  totalAmount        Decimal
  dueDate            DateTime?
  paidDate           DateTime?
  status             BillStatus   @default(UNPAID)
  invoiceUrl         String?
  notes              String?
  createdAt          DateTime     @default(now())
  updatedAt          DateTime     @updatedAt

  @@index([tenantId])
  @@index([meterId])
  @@index([status])
  @@index([dueDate])
}

enum BillStatus {
  UNPAID
  PAID
  OVERDUE
  DISPUTED
}

model Notification {
  id             String              @id @default(cuid())
  userId         String
  user           User                @relation(fields: [userId], references: [id])
  title          String
  message        String
  type           NotificationType
  priority       NotificationPriority @default(INFO)
  channel        NotificationChannel @default(IN_APP)
  isRead         Boolean             @default(false)
  readAt         DateTime?
  acknowledgedAt DateTime?
  dueAt          DateTime?
  metadata       Json?
  referenceId    String?
  referenceType  String?
  sentAt         DateTime?
  dedupeKey      String?
  createdAt      DateTime            @default(now())

  @@index([userId, createdAt])
  @@index([type])
  @@index([dedupeKey])
}

enum NotificationType {
  MAINTENANCE_DUE
  WORK_ORDER_ASSIGNED
  WORK_ORDER_UPDATED
  LOW_STOCK
  VEHICLE_SERVICE_DUE
  LICENSE_EXPIRY
  INSURANCE_EXPIRY
  UTILITY_BILL_DUE
  SLA_BREACH_WARNING
  SYSTEM_ALERT
  CLEANING_VISIT_SUBMITTED
  CLEANING_SIGN_OFF
  CLEANING_REJECTED
  FACILITY_ISSUE_REPORTED
  CLEANING_MISSED
  CLEANING_LATE_VISIT
  CLEANING_HIGH_ISSUE
  CLEANING_SLA_BREACH
}

enum NotificationPriority {
  INFO
  WARNING
  CRITICAL
}

enum NotificationChannel {
  IN_APP
  EMAIL
  SMS
  WHATSAPP
  PUSH
}

model PredictiveLog {
  id              String    @id @default(cuid())
  assetId         String?
  asset           Asset?    @relation(fields: [assetId], references: [id])
  prediction      String
  confidence      Decimal
  suggestedAction String
  riskLevel       RiskLevel
  analyzedAt      DateTime  @default(now())
  acknowledged    Boolean   @default(false)

  @@index([assetId, analyzedAt])
}

model CopilotConversation {
  id                     String              @id @default(cuid())
  userId                 String
  user                   User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  title                  String
  focusArea              String              @default("GENERAL")
  mode                   String              @default("CHAT")
  providerConversationId String?
  lastMessageAt          DateTime            @default(now())
  createdAt              DateTime            @default(now())
  updatedAt              DateTime            @updatedAt
  messages               CopilotMessage[]
  exchangeLogs           CopilotExchangeLog[]

  @@index([userId, lastMessageAt])
}

model CopilotMessage {
  id             String              @id @default(cuid())
  conversationId String
  conversation   CopilotConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  userId         String
  user           User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  role           String
  focusArea      String              @default("GENERAL")
  mode           String              @default("CHAT")
  content        String
  actions        Json?
  metadata       Json?
  createdAt      DateTime            @default(now())

  @@index([conversationId, createdAt])
  @@index([userId, createdAt])
}

model CopilotExchangeLog {
  id             String              @id @default(cuid())
  conversationId String?
  conversation   CopilotConversation? @relation(fields: [conversationId], references: [id], onDelete: SetNull)
  userId         String
  user           User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  focusArea      String              @default("GENERAL")
  mode           String              @default("CHAT")
  query          String
  response       String
  source         String              @default("fallback")
  createdAt      DateTime            @default(now())

  @@index([userId, createdAt])
  @@index([focusArea, createdAt])
  @@index([createdAt])
}

enum RiskLevel {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}


// ============================================================
// CLEANING MANAGEMENT MODULE
// Toilet/washroom cleaning with QR scan logging, scheduled
// checklists, photo upload, supervisor sign-off, and issue
// reporting. CLEANER and SUPERVISOR roles operate this module.
// ============================================================

enum CleaningFrequencyUnit {
  PER_DAY
  PER_WEEK
}

enum CleaningShift {
  MORNING
  EVENING
  NIGHT
  FLEXIBLE
}

model CleaningLocation {
  id           String              @id @default(cuid())
  tenantId     String?
  tenant       Tenant?             @relation(fields: [tenantId], references: [id])
  name         String
  area         String
  building     String?
  floor        String?
  description  String?
  qrCode       String              @unique @default(uuid())
  qrCodeUrl    String?
  scheduleCron String?
  shiftWindow  String?
  cleaningFrequency Int            @default(1)
  cleaningFrequencyUnit CleaningFrequencyUnit @default(PER_DAY)
  shiftAssignment CleaningShift    @default(MORNING)
  assignedCleanerId String?
  assignedCleaner User?            @relation("AssignedCleaningLocations", fields: [assignedCleanerId], references: [id])
  geoLatitude  Decimal?
  geoLongitude Decimal?
  geoRadiusMeters Int              @default(150)
  requireDeviceValidation Boolean  @default(false)
  requirePhotoEvidence Boolean     @default(false)
  isActive     Boolean             @default(true)
  createdAt    DateTime            @default(now())
  updatedAt    DateTime            @updatedAt

  visits             CleaningVisit[]
  checklistTemplates CleaningChecklistTemplate[]
  issues             FacilityIssue[]

  @@index([tenantId])
  @@index([isActive])
  @@index([assignedCleanerId])
}

model CleaningChecklistTemplate {
  id          String           @id @default(cuid())
  locationId  String
  location    CleaningLocation @relation(fields: [locationId], references: [id], onDelete: Cascade)
  name        String
  items       Json
  isActive    Boolean          @default(true)
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  @@index([locationId])
}

model CleaningVisit {
  id              String              @id @default(cuid())
  tenantId        String?
  tenant          Tenant?             @relation(fields: [tenantId], references: [id])
  locationId      String
  location        CleaningLocation    @relation(fields: [locationId], references: [id])
  cleanerId       String
  cleaner         User                @relation("CleanerVisits", fields: [cleanerId], references: [id])
  scannedAt       DateTime            @default(now())
  clientScannedAt DateTime?
  startedAt       DateTime?
  method          CleaningVisitMethod @default(QR_SCAN)
  deviceId        String?
  completedAt     DateTime?
  durationSeconds Int?
  latitude        Decimal?
  longitude       Decimal?
  geofenceDistanceMeters Decimal?
  geoValidated    Boolean             @default(false)
  beforePhotos    String[]
  afterPhotos     String[]
  checklistScore  Int?
  photoScore      Int?
  qualityScore    Int?
  scheduleStatus  CleaningScheduleStatus @default(ON_TIME)
  status          CleaningVisitStatus @default(IN_PROGRESS)
  notes           String?
  signedOffById   String?
  signedOffBy     User?               @relation("SupervisorSignOffs", fields: [signedOffById], references: [id])
  signedOffAt     DateTime?
  signOffNotes    String?
  supervisorRating Int?
  supervisorComment String?
  rejectionReason String?
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt

  checklist CleaningChecklist?

  @@index([tenantId])
  @@index([locationId, scannedAt])
  @@index([cleanerId, scannedAt])
  @@index([status])
  @@index([scheduleStatus])
}

enum CleaningScheduleStatus {
  ON_TIME
  LATE
}

enum CleaningVisitStatus {
  IN_PROGRESS
  COMPLETED
  PENDING_VERIFICATION
  SUBMITTED
  APPROVED
  REJECTED
}

enum CleaningVisitMethod {
  QR_SCAN
  MANUAL
}

model CleaningChecklist {
  id          String        @id @default(cuid())
  visitId     String        @unique
  visit       CleaningVisit @relation(fields: [visitId], references: [id], onDelete: Cascade)
  items       Json
  completedAt DateTime?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
}

model FacilityIssue {
  id           String                @id @default(cuid())
  tenantId     String?
  tenant       Tenant?               @relation(fields: [tenantId], references: [id])
  locationId   String?
  location     CleaningLocation?     @relation(fields: [locationId], references: [id])
  reportedById String
  reportedBy   User                  @relation("ReportedFacilityIssues", fields: [reportedById], references: [id])
  assignedToId String?
  assignedTo   User?                 @relation("AssignedFacilityIssues", fields: [assignedToId], references: [id])
  title        String
  description  String
  severity     IssueSeverity         @default(MEDIUM)
  status       FacilityIssueStatus   @default(OPEN)
  photos       String[]
  slaTargetAt  DateTime?
  firstResponseAt DateTime?
  resolvedById String?
  resolvedBy   User?                 @relation("ResolvedFacilityIssues", fields: [resolvedById], references: [id])
  resolvedAt   DateTime?
  closedAt     DateTime?
  resolutionMinutes Int?
  resolution   String?
  createdAt    DateTime              @default(now())
  updatedAt    DateTime              @updatedAt

  @@index([tenantId])
  @@index([locationId])
  @@index([reportedById])
  @@index([assignedToId])
  @@index([status])
  @@index([severity])
  @@index([slaTargetAt])
}

enum IssueSeverity {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum FacilityIssueStatus {
  OPEN
  IN_PROGRESS
  RESOLVED
  CLOSED
}
