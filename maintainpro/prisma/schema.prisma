generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mongodb"
  url      = env("MONGODB_URI")
}

model Tenant {
  id         String       @id @default(auto()) @map("_id") @db.ObjectId
  name       String
  slug       String       @unique
  isActive   Boolean      @default(true)
  createdAt  DateTime     @default(now())
  updatedAt  DateTime     @updatedAt

  memberships    TenantMembership[]
  invitations    TenantInvitation[]
  subscriptions  Subscription[]
  usageMetrics   UsageMetric[]
  usageEvents    UsageEvent[]
  stripeCustomer StripeCustomer?
  stripeInvoices StripeInvoice[]
  users          User[]
  roles          Role[]
  assets         Asset[]
  vehicles       Vehicle[]
  drivers        Driver[]
  workOrders     WorkOrder[]
  spareParts     SparePart[]
  suppliers      Supplier[]
  meters         UtilityMeter[]
  bills          UtilityBill[]
  audits         AuditLog[]
  cleaningLocations CleaningLocation[]
  cleaningVisits    CleaningVisit[]
  facilityIssues    FacilityIssue[]
}

model AuditLog {
  id         String      @id @default(auto()) @map("_id") @db.ObjectId
  tenantId   String?     @db.ObjectId
  tenant     Tenant?     @relation(fields: [tenantId], references: [id])
  entity     String
  entityId   String
  action     AuditAction
  actorId    String?     @db.ObjectId
  actor      User?       @relation(fields: [actorId], references: [id])
  beforeData Json?
  afterData  Json?
  createdAt  DateTime    @default(now())

  @@index([entity, entityId])
  @@index([tenantId])
}

model AppSetting {
  id        String          @id @default(auto()) @map("_id") @db.ObjectId
  scope     AppSettingScope @default(GLOBAL)
  scopeId   String          @default("GLOBAL")
  key       String
  value     Json
  isSecret  Boolean         @default(false)
  createdAt DateTime        @default(now())
  updatedAt DateTime        @updatedAt

  @@unique([scope, scopeId, key])
  @@index([key])
  @@index([scope, scopeId])
}

enum AppSettingScope {
  GLOBAL
  TENANT
  USER
}

enum AuditAction {
  CREATE
  UPDATE
  DELETE
}

model Permission {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  key         String   @unique
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  roles   Role[]   @relation(fields: [roleIds], references: [id])
  roleIds String[] @db.ObjectId
}

model User {
  id           String   @id @default(auto()) @map("_id") @db.ObjectId
  tenantId     String?  @db.ObjectId
  tenant       Tenant?  @relation(fields: [tenantId], references: [id])
  email        String   @unique
  passwordHash String
  firstName    String
  lastName     String
  phone        String?
  avatar       String?
  roleId       String   @db.ObjectId
  role         Role     @relation(fields: [roleId], references: [id])
  isActive     Boolean  @default(true)
  lastLogin    DateTime?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  assignedWorkOrders        WorkOrder[]            @relation("TechnicianWorkOrders")
  createdWorkOrders         WorkOrder[]            @relation("CreatorWorkOrders")
  memberships               TenantMembership[]
  sentInvitations           TenantInvitation[]     @relation("TenantInvitedBy")
  notifications             Notification[]
  auditEvents               AuditLog[]
  driverProfile             Driver?
  cleaningVisits            CleaningVisit[]        @relation("CleanerVisits")
  signedOffVisits           CleaningVisit[]        @relation("SupervisorSignOffs")
  assignedCleaningLocations CleaningLocation[]     @relation("AssignedCleaningLocations")
  reportedIssues            FacilityIssue[]        @relation("ReportedFacilityIssues")
  resolvedIssues            FacilityIssue[]        @relation("ResolvedFacilityIssues")
  assignedFacilityIssues    FacilityIssue[]        @relation("AssignedFacilityIssues")
  copilotConversations      CopilotConversation[]
  copilotMessages           CopilotMessage[]
  copilotExchangeLogs       CopilotExchangeLog[]

  @@index([tenantId])
  @@index([roleId])
}

model Role {
  id          String       @id @default(auto()) @map("_id") @db.ObjectId
  tenantId    String?      @db.ObjectId
  tenant      Tenant?      @relation(fields: [tenantId], references: [id])
  name        RoleName
  permissions Permission[] @relation(fields: [permissionIds], references: [id])
  permissionIds String[]   @db.ObjectId
  users       User[]
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  @@index([tenantId, name])
  @@index([tenantId])
}

enum RoleName {
  SUPER_ADMIN
  ADMIN
  MANAGER
  TECHNICIAN
  MECHANIC
  ASSET_MANAGER
  INVENTORY_KEEPER
  SUPERVISOR
  CLEANER
  DRIVER
  VIEWER
  FARM_OWNER
  FARM_MANAGER
  FIELD_SUPERVISOR
  AGRONOMIST
  VETERINARIAN
  FARM_WORKER
  IRRIGATION_OPERATOR
  HARVEST_CREW
}

model TenantMembership {
  id             String               @id @default(auto()) @map("_id") @db.ObjectId
  tenantId       String               @db.ObjectId
  tenant         Tenant               @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  userId         String               @db.ObjectId
  user           User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  membershipRole TenantMembershipRole @default(MEMBER)
  joinedAt       DateTime             @default(now())
  createdAt      DateTime             @default(now())
  updatedAt      DateTime             @updatedAt

  @@unique([tenantId, userId])
  @@index([userId])
  @@index([tenantId, membershipRole])
}

enum TenantMembershipRole {
  OWNER
  ADMIN
  MEMBER
  BILLING
}

model TenantInvitation {
  id             String                 @id @default(auto()) @map("_id") @db.ObjectId
  tenantId       String                 @db.ObjectId
  tenant         Tenant                 @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  email          String
  firstName      String?
  lastName       String?
  membershipRole TenantMembershipRole   @default(MEMBER)
  invitedById    String                 @db.ObjectId
  invitedBy      User                   @relation("TenantInvitedBy", fields: [invitedById], references: [id], onDelete: Cascade)
  token          String                 @unique
  status         TenantInvitationStatus @default(PENDING)
  expiresAt      DateTime
  acceptedAt     DateTime?
  createdAt      DateTime               @default(now())
  updatedAt      DateTime               @updatedAt

  @@index([tenantId, email])
  @@index([invitedById])
  @@index([status, expiresAt])
}

enum TenantInvitationStatus {
  PENDING
  ACCEPTED
  EXPIRED
  REVOKED
}

model Plan {
  id            String         @id @default(auto()) @map("_id") @db.ObjectId
  code          String         @unique
  name          String
  description   String?
  isActive      Boolean        @default(true)
  currency      String         @default("USD")
  priceMonthly  Float          @default(0)
  priceYearly   Float          @default(0)
  metadata      Json?
  entitlements  Entitlement[]
  subscriptions Subscription[]
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
}

model Subscription {
  id                   String             @id @default(auto()) @map("_id") @db.ObjectId
  tenantId             String             @db.ObjectId
  tenant               Tenant             @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  planId               String             @db.ObjectId
  plan                 Plan               @relation(fields: [planId], references: [id])
  status               SubscriptionStatus @default(TRIALING)
  billingInterval      BillingInterval    @default(MONTHLY)
  seats                Int                @default(5)
  isCurrent            Boolean            @default(true)
  startedAt            DateTime           @default(now())
  currentPeriodStart   DateTime           @default(now())
  currentPeriodEnd     DateTime?
  cancelAtPeriodEnd    Boolean            @default(false)
  canceledAt           DateTime?
  stripeSubscriptionId String?            @unique
  stripePriceId        String?
  invoices             StripeInvoice[]
  createdAt            DateTime           @default(now())
  updatedAt            DateTime           @updatedAt

  @@index([tenantId, isCurrent])
  @@index([status])
  @@index([planId])
}

enum SubscriptionStatus {
  TRIALING
  ACTIVE
  PAST_DUE
  CANCELED
  INCOMPLETE
  PAUSED
}

enum BillingInterval {
  MONTHLY
  YEARLY
}

model Entitlement {
  id          String          @id @default(auto()) @map("_id") @db.ObjectId
  planId      String          @db.ObjectId
  plan        Plan            @relation(fields: [planId], references: [id], onDelete: Cascade)
  key         String
  type        EntitlementType @default(FEATURE)
  enabled     Boolean         @default(true)
  limitValue  Int?
  unit        String?
  overageRate Float?
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  @@unique([planId, key])
  @@index([key])
}

enum EntitlementType {
  FEATURE
  LIMIT
}

model UsageMetric {
  id          String            @id @default(auto()) @map("_id") @db.ObjectId
  tenantId    String            @db.ObjectId
  tenant      Tenant            @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  key         String
  window      UsageMetricWindow @default(MONTHLY)
  periodStart DateTime
  periodEnd   DateTime
  value       Int               @default(0)
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt

  @@unique([tenantId, key, window, periodStart])
  @@index([tenantId, periodEnd])
}

enum UsageMetricWindow {
  DAILY
  MONTHLY
}

model UsageEvent {
  id         String         @id @default(auto()) @map("_id") @db.ObjectId
  tenantId   String         @db.ObjectId
  tenant     Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  key        String
  eventType  UsageEventType @default(CONSUME)
  quantity   Int            @default(1)
  metadata   Json?
  occurredAt DateTime       @default(now())

  @@index([tenantId, key, occurredAt])
}

enum UsageEventType {
  CONSUME
  CREDIT
  RESET
}

model StripeCustomer {
  id         String   @id @default(auto()) @map("_id") @db.ObjectId
  tenantId   String   @unique @db.ObjectId
  tenant     Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  customerId String   @unique
  email      String?
  name       String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model StripeInvoice {
  id               String        @id @default(auto()) @map("_id") @db.ObjectId
  tenantId         String        @db.ObjectId
  tenant           Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  subscriptionId   String?       @db.ObjectId
  subscription     Subscription? @relation(fields: [subscriptionId], references: [id], onDelete: SetNull)
  stripeInvoiceId  String        @unique
  invoiceNumber    String?
  amountDue        Float         @default(0)
  amountPaid       Float         @default(0)
  currency         String        @default("usd")
  status           String
  hostedInvoiceUrl String?
  invoicePdf       String?
  dueDate          DateTime?
  paidAt           DateTime?
  periodStart      DateTime?
  periodEnd        DateTime?
  raw              Json?
  createdAt        DateTime      @default(now())

  @@index([tenantId, createdAt])
  @@index([subscriptionId])
}

model Asset {
  id              String         @id @default(auto()) @map("_id") @db.ObjectId
  tenantId        String?        @db.ObjectId
  tenant          Tenant?        @relation(fields: [tenantId], references: [id])
  assetTag        String         @unique
  name            String
  description     String?
  category        AssetCategory
  condition       AssetCondition @default(GOOD)
  status          AssetStatus    @default(ACTIVE)
  purchaseDate    DateTime?
  purchasePrice   Float?
  supplier        String?
  department      String?
  ownerName       String?
  currentValue    Float?
  location        String?
  manufacturer    String?
  model           String?
  serialNumber    String?
  meterReading    Float?
  lastServiceDate DateTime?
  nextServiceDate DateTime?
  warrantyExpiry  DateTime?
  disposalDate    DateTime?
  disposalReason  String?
  archivedAt      DateTime?
  images          String[]
  documents       String[]
  qrCodeUrl       String?
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  maintenanceLogs      MaintenanceLog[]
  maintenanceSchedules MaintenanceSchedule[]
  workOrders           WorkOrder[]
  predictiveLogs       PredictiveLog[]

  @@index([tenantId])
  @@index([status])
  @@index([category])
  @@index([condition])
  @@index([archivedAt])
  @@index([nextServiceDate])
}

enum AssetStatus {
  ACTIVE
  INACTIVE
  UNDER_MAINTENANCE
  DISPOSED
  RETIRED
}

enum AssetCategory {
  MACHINE
  TOOL
  INFRASTRUCTURE
  EQUIPMENT
  VEHICLE
  OTHER
  TRACTOR
  HARVESTER
  SPRAYER
  IRRIGATION_PUMP
  IRRIGATION_PIPE
  GREENHOUSE
  BARN
  STORAGE_SILO
  COLD_ROOM
  MILKING_MACHINE
}

enum AssetCondition {
  EXCELLENT
  GOOD
  FAIR
  POOR
  CRITICAL
}

model Vehicle {
  id                 String        @id @default(auto()) @map("_id") @db.ObjectId
  tenantId           String?       @db.ObjectId
  tenant             Tenant?       @relation(fields: [tenantId], references: [id])
  registrationNo     String        @unique
  make               String
  vehicleModel       String
  year               Int
  type               VehicleType
  status             VehicleStatus @default(AVAILABLE)
  color              String?
  vin                String?       @unique
  engineNo           String?
  fuelType           FuelType
  fuelCapacity       Float?
  currentMileage     Float         @default(0)
  insuranceExpiry    DateTime?
  roadTaxExpiry      DateTime?
  lastServiceDate    DateTime?
  nextServiceDate    DateTime?
  nextServiceMileage Float?
  gpsDeviceId        String?
  images             String[]
  driverId           String?       @db.ObjectId
  driver             Driver?       @relation(fields: [driverId], references: [id])
  createdAt          DateTime      @default(now())
  updatedAt          DateTime      @updatedAt

  fuelLogs             FuelLog[]
  tripLogs             TripLog[]
  maintenanceSchedules MaintenanceSchedule[]
  maintenanceLogs      MaintenanceLog[]
  workOrders           WorkOrder[]
  gpsLocations         GpsLocation[]

  @@index([tenantId])
  @@index([status])
  @@index([driverId])
}

enum VehicleType {
  CAR
  MOTORCYCLE
  TRUCK
  VAN
  BUS
  HEAVY_EQUIPMENT
  OTHER
}

enum VehicleStatus {
  AVAILABLE
  IN_USE
  UNDER_MAINTENANCE
  OUT_OF_SERVICE
  DISPOSED
}

enum FuelType {
  PETROL
  DIESEL
  ELECTRIC
  HYBRID
  CNG
  LPG
}

model Driver {
  id            String   @id @default(auto()) @map("_id") @db.ObjectId
  tenantId      String?  @db.ObjectId
  tenant        Tenant?  @relation(fields: [tenantId], references: [id])
  userId        String   @unique @db.ObjectId
  user          User     @relation(fields: [userId], references: [id])
  licenseNumber String   @unique
  licenseClass  String
  licenseExpiry DateTime
  isAvailable   Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  vehicles Vehicle[]
  tripLogs TripLog[]

  @@index([tenantId])
}

model FuelLog {
  id            String   @id @default(auto()) @map("_id") @db.ObjectId
  vehicleId     String   @db.ObjectId
  vehicle       Vehicle  @relation(fields: [vehicleId], references: [id])
  date          DateTime
  liters        Float
  costPerLiter  Float
  totalCost     Float
  mileageAtFuel Float
  fuelStation   String?
  receiptUrl    String?
  notes         String?
  createdAt     DateTime @default(now())

  @@index([vehicleId, date])
}

model TripLog {
  id            String     @id @default(auto()) @map("_id") @db.ObjectId
  vehicleId     String     @db.ObjectId
  vehicle       Vehicle    @relation(fields: [vehicleId], references: [id])
  driverId      String     @db.ObjectId
  driver        Driver     @relation(fields: [driverId], references: [id])
  startLocation String
  endLocation   String
  startMileage  Float
  endMileage    Float
  distance      Float
  startTime     DateTime
  endTime       DateTime?
  purpose       String?
  status        TripStatus @default(IN_PROGRESS)
  notes         String?
  createdAt     DateTime   @default(now())

  @@index([vehicleId, startTime])
  @@index([driverId, startTime])
}

enum TripStatus {
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

model GpsLocation {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  vehicleId String   @db.ObjectId
  vehicle   Vehicle  @relation(fields: [vehicleId], references: [id])
  latitude  Float
  longitude Float
  speed     Float?
  heading   Float?
  timestamp DateTime @default(now())

  @@index([vehicleId, timestamp])
}

model MaintenanceSchedule {
  id              String               @id @default(auto()) @map("_id") @db.ObjectId
  name            String
  description     String?
  type            MaintenanceType
  frequency       MaintenanceFrequency
  intervalDays    Int?
  intervalMileage Float?
  assetId         String?              @db.ObjectId
  asset           Asset?               @relation(fields: [assetId], references: [id])
  vehicleId       String?              @db.ObjectId
  vehicle         Vehicle?             @relation(fields: [vehicleId], references: [id])
  nextDueDate     DateTime?
  nextDueMileage  Float?
  isActive        Boolean              @default(true)
  estimatedCost   Float?
  estimatedHours  Float?
  createdAt       DateTime             @default(now())
  updatedAt       DateTime             @updatedAt

  maintenanceLogs MaintenanceLog[]
  workOrders      WorkOrder[]

  @@index([assetId])
  @@index([vehicleId])
  @@index([nextDueDate])
}

enum MaintenanceType {
  PREVENTIVE
  PREDICTIVE
  CORRECTIVE
  INSPECTION
}

enum MaintenanceFrequency {
  DAILY
  WEEKLY
  MONTHLY
  QUARTERLY
  BIANNUAL
  ANNUAL
  MILEAGE_BASED
  CUSTOM
}

model MaintenanceLog {
  id          String               @id @default(auto()) @map("_id") @db.ObjectId
  scheduleId  String?              @db.ObjectId
  schedule    MaintenanceSchedule? @relation(fields: [scheduleId], references: [id])
  assetId     String?              @db.ObjectId
  asset       Asset?               @relation(fields: [assetId], references: [id])
  vehicleId   String?              @db.ObjectId
  vehicle     Vehicle?             @relation(fields: [vehicleId], references: [id])
  workOrderId String?              @db.ObjectId
  workOrder   WorkOrder?           @relation(fields: [workOrderId], references: [id])
  description String
  performedBy String
  performedAt DateTime
  cost        Float?
  notes       String?
  attachments String[]
  createdAt   DateTime             @default(now())

  @@index([scheduleId])
  @@index([assetId])
  @@index([vehicleId])
  @@index([performedAt])
}

model WorkOrder {
  id             String               @id @default(auto()) @map("_id") @db.ObjectId
  tenantId       String?              @db.ObjectId
  tenant         Tenant?              @relation(fields: [tenantId], references: [id])
  woNumber       String               @unique
  title          String
  description    String
  priority       Priority             @default(MEDIUM)
  status         WorkOrderStatus      @default(OPEN)
  type           WorkOrderType
  assetId        String?              @db.ObjectId
  asset          Asset?               @relation(fields: [assetId], references: [id])
  vehicleId      String?              @db.ObjectId
  vehicle        Vehicle?             @relation(fields: [vehicleId], references: [id])
  scheduleId     String?              @db.ObjectId
  schedule       MaintenanceSchedule? @relation(fields: [scheduleId], references: [id])
  createdById    String               @db.ObjectId
  createdBy      User                 @relation("CreatorWorkOrders", fields: [createdById], references: [id])
  technicianId   String?              @db.ObjectId
  technician     User?                @relation("TechnicianWorkOrders", fields: [technicianId], references: [id])
  dueDate        DateTime?
  startDate      DateTime?
  completedDate  DateTime?
  estimatedCost  Float?
  actualCost     Float?
  estimatedHours Float?
  actualHours    Float?
  slaDeadline    DateTime?
  slaBreached    Boolean              @default(false)
  notes          String?
  attachments    String[]
  createdAt      DateTime             @default(now())
  updatedAt      DateTime             @updatedAt

  maintenanceLogs MaintenanceLog[]
  parts           WorkOrderPart[]

  @@index([tenantId])
  @@index([status])
  @@index([priority])
  @@index([technicianId])
}

enum Priority {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum WorkOrderStatus {
  OPEN
  IN_PROGRESS
  ON_HOLD
  COMPLETED
  CANCELLED
  OVERDUE
}

enum WorkOrderType {
  PREVENTIVE
  CORRECTIVE
  EMERGENCY
  INSPECTION
  INSTALLATION
  PLANTING
  HARVESTING
  SPRAYING
  FERTILIZING
  PRUNING
  WEEDING
  LAND_PREPARATION
  LIVESTOCK_CARE
  IRRIGATION_REPAIR
  SOIL_PREPARATION
  POST_HARVEST
}

model SparePart {
  id              String    @id @default(auto()) @map("_id") @db.ObjectId
  tenantId        String?   @db.ObjectId
  tenant          Tenant?   @relation(fields: [tenantId], references: [id])
  partNumber      String    @unique
  name            String
  description     String?
  category        String
  unit            String    @default("pcs")
  quantityInStock Int       @default(0)
  minimumStock    Int       @default(0)
  reorderPoint    Int       @default(0)
  unitCost        Float
  location        String?
  supplierId      String?   @db.ObjectId
  supplier        Supplier? @relation(fields: [supplierId], references: [id])
  images          String[]
  isActive        Boolean   @default(true)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  stockMovements StockMovement[]
  workOrderParts WorkOrderPart[]

  @@index([tenantId])
  @@index([supplierId])
}

model StockMovement {
  id        String       @id @default(auto()) @map("_id") @db.ObjectId
  partId    String       @db.ObjectId
  part      SparePart    @relation(fields: [partId], references: [id])
  type      MovementType
  quantity  Int
  reference String?
  notes     String?
  createdAt DateTime     @default(now())

  @@index([partId, createdAt])
}

enum MovementType {
  IN
  OUT
  ADJUSTMENT
  RETURN
}

model WorkOrderPart {
  id          String    @id @default(auto()) @map("_id") @db.ObjectId
  workOrderId String    @db.ObjectId
  workOrder   WorkOrder @relation(fields: [workOrderId], references: [id])
  partId      String    @db.ObjectId
  part        SparePart @relation(fields: [partId], references: [id])
  quantity    Int
  unitCost    Float
  totalCost   Float

  @@index([workOrderId])
  @@index([partId])
}

model Supplier {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  tenantId    String?  @db.ObjectId
  tenant      Tenant?  @relation(fields: [tenantId], references: [id])
  name        String
  contactName String?
  email       String?
  phone       String?
  address     String?
  website     String?
  taxNumber   String?
  isActive    Boolean  @default(true)
  notes       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  spareParts     SparePart[]
  purchaseOrders PurchaseOrder[]

  @@index([tenantId])
}

model PurchaseOrder {
  id           String    @id @default(auto()) @map("_id") @db.ObjectId
  poNumber     String    @unique
  supplierId   String    @db.ObjectId
  supplier     Supplier  @relation(fields: [supplierId], references: [id])
  status       POStatus  @default(PENDING)
  orderDate    DateTime
  expectedDate DateTime?
  receivedDate DateTime?
  totalAmount  Float
  notes        String?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  @@index([supplierId])
}

enum POStatus {
  PENDING
  ORDERED
  PARTIALLY_RECEIVED
  RECEIVED
  CANCELLED
}

model UtilityMeter {
  id          String      @id @default(auto()) @map("_id") @db.ObjectId
  tenantId    String?     @db.ObjectId
  tenant      Tenant?     @relation(fields: [tenantId], references: [id])
  meterNumber String      @unique
  type        UtilityType
  location    String
  description String?
  unit        String
  isActive    Boolean     @default(true)
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  readings MeterReading[]
  bills    UtilityBill[]

  @@index([tenantId])
}

enum UtilityType {
  ELECTRICITY
  WATER
  GAS
}

model MeterReading {
