# Vercel public variables
NEXT_PUBLIC_API_URL=https://your-render-api.onrender.com/api
NEXT_PUBLIC_API_TIMEOUT_MS=60000

# Backward-compatible aliases used by older builds and websocket clients.
NEXT_PUBLIC_API_BASE_URL=https://your-render-api.onrender.com/api
NEXT_PUBLIC_API_ORIGIN=https://your-render-api.onrender.com

# Optional local-dev only: allow bare seed aliases (e.g. "admin" -> admin@maintainpro.local).
# Leave unset/false in production. Backend login always expects a valid email.
# NEXT_PUBLIC_LOGIN_DEV_LOCAL_ALIAS=true
