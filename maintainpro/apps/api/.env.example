NODE_ENV=production
PORT=10000

# Public URLs
CORS_ORIGIN=https://your-vercel-app.vercel.app
FRONTEND_URL=https://your-vercel-app.vercel.app

# MongoDB Atlas
DATABASE_URL=mongodb+srv://<db-user>:<db-password>@<cluster-host>/<database>?retryWrites=true&w=majority
MONGODB_URI=mongodb+srv://<db-user>:<db-password>@<cluster-host>/<database>?retryWrites=true&w=majority
MONGO_SYNC_ON_STARTUP=false

# JWT auth. Render can use only JWT_SECRET, or separate access/refresh secrets.
JWT_SECRET=replace_with_64_character_random_secret
JWT_ACCESS_SECRET=
JWT_REFRESH_SECRET=
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=7d

# Optional Redis-backed queues. Leave blank to run without a managed Redis during low-cost trials.
REDIS_URL=

# Persistent file storage. Cloudinary is recommended for Render free tier.
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
CLOUDINARY_ASSET_FOLDER=maintainpro/asset-documents

# Optional S3/MinIO-compatible storage health checks.
MINIO_ENDPOINT=
MINIO_PORT=443
MINIO_USE_SSL=true
MINIO_ACCESS_KEY=
MINIO_SECRET_KEY=
MINIO_BUCKET=

# Optional email / notifications
SENDGRID_API_KEY=
SMTP_HOST=
SMTP_PORT=
SMTP_USER=
SMTP_PASS=
SMTP_FROM=MaintainPro Alerts <alerts@example.com>
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# Optional billing and identity providers
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=https://your-render-api.onrender.com/api/auth/google/callback

# Optional premium integrations
RAPIDAPI_GOOGLE_MAP_PLACES_KEY=
RAPIDAPI_COPILOT_API_KEY=
RAPIDAPI_COPILOT_HOST=copilot5.p.rapidapi.com
RAPIDAPI_QR_CODE_API_KEY=
RAPIDAPI_QR_CODE_HOST=simple-qr-code-generator-cheap-and-efficient.p.rapidapi.com
RAPIDAPI_QR_CODE_COLOR=
RAPIDAPI_QR_CODE_BG_COLOR=
OPENWEATHER_API_KEY=
FARM_DEFAULT_LATITUDE=6.9271
FARM_DEFAULT_LONGITUDE=79.8612
WEATHER_ALERT_FROST_THRESHOLD_C=5
WEATHER_ALERT_RAIN_THRESHOLD_MM=50
TRACEABILITY_PUBLIC_BASE_URL=https://your-vercel-app.vercel.app/trace
APP_VERSION=1.2.0
