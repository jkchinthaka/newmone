{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Tenant fail-open audit exceptions",
  "type": "object",
  "required": ["exceptions"],
  "properties": {
    "$schema": { "type": "string" },
    "description": { "type": "string" },
    "exceptions": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["file", "scope", "owner", "status", "reason"],
        "properties": {
          "file": { "type": "string", "description": "Repo-relative path from maintainpro/ (e.g. apps/api/src/modules/...)" },
          "scope": { "type": "string", "enum": ["platform-super-admin", "actor-guard-protected", "tenant-owned-business"] },
          "owner": { "type": "string" },
          "status": { "type": "string", "enum": ["APPROVED", "PENDING-MIGRATION"] },
          "reason": { "type": "string" }
        },
        "additionalProperties": false
      }
    }
  }
}